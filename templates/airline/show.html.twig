{% extends 'base.html.twig' %}

{% block title %}{{ airline.name }} bagage | Handbagage & ruimbagage regels | Topbags{% endblock %}

{% block body %}

{# =========================
   HERO
========================= #}
<section class="bg-amber-50 border-b border-amber-200">
    <div class="max-w-7xl mx-auto px-6 py-12 grid md:grid-cols-2 gap-10 items-center">

        <div>
            <div class="inline-flex items-center gap-2 text-amber-700 text-xs font-semibold uppercase tracking-wide">
                <span class="inline-block w-2 h-2 rounded-full bg-amber-500"></span>
                Airline bagagegids
            </div>

            <h1 class="text-3xl md:text-4xl font-semibold text-gray-900 mt-3 mb-4">
                Bagage meenemen bij {{ airline.name }}
            </h1>

            <p class="text-gray-700 max-w-xl">
                Duidelijke handbagage- en ruimbagage-info voor {{ airline.name }}.
                Daarna kun je met onze gids bepalen wat voor jouw reis het meest logisch is — zonder verrassingen bij de gate.
            </p>

            <div class="mt-6 flex flex-col sm:flex-row gap-3">
                <a href="{{ path('guide_index', { transport: 'plane', airline: airline.slug }) }}"
                   class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-black text-white text-sm font-medium hover:bg-gray-900 transition">
                    Start persoonlijk bagage-advies →
                </a>

                <a href="#tickets"
                   class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-white border border-gray-300 text-sm font-medium hover:border-black transition">
                    Bekijk ticketregels
                </a>
            </div>

            <p class="text-xs text-gray-500 mt-3">
                Tip: je hebt meestal <strong>één hoofdkeuze</strong> nodig (handbagage óf ruimbagage). De gids helpt je kiezen.
            </p>
        </div>

        <div class="flex md:justify-end">
            <div class="bg-white border border-amber-200 rounded-2xl p-6 shadow-sm">
                <img src="{{ asset('images/airline/' ~ airline.logo) }}" alt="{{ airline.name }} logo" class="h-14 w-auto">
                <div class="mt-4 text-sm text-gray-700">
                    Snelle check:
                    <ul class="mt-2 space-y-1 text-gray-600">
                        <li>• Personal item: vaak gratis</li>
                        <li>• Handbagagekoffer: meestal alleen met Priority</li>
                        <li>• Ruimbagage: afhankelijk van ticket / bijboeken</li>
                    </ul>
                </div>
            </div>
        </div>

    </div>
</section>

{# =========================
   ALGEMEEN OVERZICHT
========================= #}
<section class="max-w-7xl mx-auto px-6 py-12">
    <div class="grid md:grid-cols-3 gap-6 items-stretch">

        {# =====================
           PERSONAL ITEM
        ===================== #}
        <div class="bg-white border border-gray-200 rounded-xl p-6
                    flex flex-col h-full">
            <div>
                <h2 class="font-semibold text-gray-900 mb-2">
                    Personal item
                </h2>

                <div class="text-sm text-gray-700">
                    Kleine tas of rugzak die onder de stoel past.
                </div>
            </div>

            {% if fallbackSummary.personal.allowed %}
                <div class="mt-auto pt-4">
                    <div class="inline-flex items-center gap-2 text-sm
                                bg-amber-50 border border-amber-200
                                rounded-lg px-3 py-2">
                        <span class="text-amber-700 font-semibold">
                            {{ fallbackSummary.personal.maxHeightCm }}
                            × {{ fallbackSummary.personal.maxWidthCm }}
                            × {{ fallbackSummary.personal.maxDepthCm }} cm
                        </span>
                       {% if fallbackSummary.personal.maxWeightKg %}
                            <span class="text-gray-500">
                                · {{ fallbackSummary.personal.maxWeightKg }} kg
                            </span>
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        </div>

        {# =====================
           HANDBAGAGE
        ===================== #}
        <div class="bg-white border border-gray-200 rounded-xl p-6
                    flex flex-col h-full">
            <div>
                <h2 class="font-semibold text-gray-900 mb-2">
                    Handbagage
                </h2>

                <div class="text-sm text-gray-700">
                    Handbagagekoffer voor in het bagagevak.
                    Meestal alleen toegestaan bij bepaalde tickets.
                </div>
            </div>

            {% if fallbackSummary.cabin.allowed %}
                <div class="mt-auto pt-4">
                    <div class="inline-flex items-center gap-2 text-sm
                                bg-amber-50 border border-amber-200
                                rounded-lg px-3 py-2">
                        <span class="text-amber-700 font-semibold">
                            {{ fallbackSummary.cabin.maxHeightCm }}
                            × {{ fallbackSummary.cabin.maxWidthCm }}
                            × {{ fallbackSummary.cabin.maxDepthCm }} cm
                        </span>

                        {% if fallbackSummary.cabin.maxWeightKg %}
                            <span class="text-gray-500">
                                · {{ fallbackSummary.cabin.maxWeightKg }} kg
                            </span>
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        </div>

        {# =====================
           RUIMBAGAGE
        ===================== #}
        <div class="bg-white border border-gray-200 rounded-xl p-6
                    flex flex-col h-full">
            <div>
                <h2 class="font-semibold text-gray-900 mb-2">
                    Ruimbagage
                </h2>

                <div class="text-sm text-gray-700">
                    In te checken bagage.
                    Afmetingen en gewicht hangen af van je ticket.
                </div>
            </div>

            {% if fallbackSummary.hold.allowed %}
                <div class="mt-auto pt-4">
                    <div class="inline-flex items-center gap-2 text-sm
                                bg-amber-50 border border-amber-200
                                rounded-lg px-3 py-2">
                        {% if fallbackSummary.hold.dimensionType == 'linear_sum' %}
                            <span class="text-amber-700 font-semibold">
                                {{ fallbackSummary.hold.maxLinearCm }} cm totaal
                            </span>
                        {% else %}
                            <span class="text-amber-700 font-semibold">
                                {{ fallbackSummary.hold.maxHeightCm }}
                                × {{ fallbackSummary.hold.maxWidthCm }}
                                × {{ fallbackSummary.hold.maxDepthCm }} cm
                            </span>
                        {% endif %}

                        {% if fallbackSummary.hold.maxWeightKg %}
                            <span class="text-gray-500">
                                · {{ fallbackSummary.hold.maxWeightKg }} kg
                            </span>
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        </div>

    </div> 

    {# =====================
       UITLEG BLOK
    ===================== #}
    <div class="mt-8 rounded-xl bg-amber-50 border border-amber-200 p-6">
        <h3 class="font-semibold text-gray-900 mb-2">
            Belangrijk: je hebt meestal maar één hoofdkeuze nodig
        </h3>
        <p class="text-sm text-gray-700 max-w-3xl">
            De meeste reizigers kiezen óf voor handbagage (snel & compact),
            óf voor ruimbagage (meer ruimte & comfort).
            In de bagage-gids helpen we je bepalen wat past bij jouw reisduur en type trip.
        </p>
    </div>
</section>

{# =========================
   TICKETTYPES (DB-gedreven)
========================= #}
<section id="tickets" class="max-w-7xl mx-auto px-6 pb-14">

    {% set ticketTypes = airline.ticketTypes %}

    <div class="flex items-end justify-between gap-6 mb-6">
        <div>
            <h2 class="text-2xl font-semibold text-gray-900">
                {{ airline.name }} tickets en bagage
            </h2>
            <p class="text-gray-600 text-sm max-w-2xl mt-2">
                Je ticket bepaalt wat je mee mag nemen.
                Hieronder zie je per ticket exact wat is toegestaan.
            </p>
        </div>

      <a href="{{ path('guide_index', {
            transport: 'plane',
            airline: airline.slug
        }) }}"
        class="hidden md:inline-flex items-center justify-center px-5 py-2.5
            rounded-lg bg-black text-white text-sm font-medium
            hover:bg-gray-900 transition">
            Start de gids →
        </a>
            </div>

    {% if ticketTypes|length == 0 %}
        <p class="text-sm text-gray-500">
            Geen ticketinformatie beschikbaar voor {{ airline.name }}.
        </p>
    {% else %}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

            {% for t in ticketTypes %}
                {% if t.isActive %}
                    {% set summary = ticketSummaries[t.slug] ?? null %}

                    <div class="bg-white border border-gray-200 rounded-xl p-6
                                hover:shadow-sm transition
                                flex flex-col h-full">

                        {# =====================
                           Header
                        ===================== #}
                        <div>
                            <div class="flex items-start justify-between gap-4">
                                <div>
                                    <div class="text-lg font-semibold text-gray-900">
                                        {{ t.name }}
                                    </div>

                                    {% if t.description %}
                                        <div class="text-sm text-gray-600 mt-1">
                                            {{ t.description }}
                                        </div>
                                    {% endif %}
                                </div>

                                <span class="text-xs px-2 py-1 rounded-full
                                             bg-amber-100 text-amber-800 font-semibold">
                                    Ticket
                                </span>
                            </div>

                            {# =====================
                               BAGAGE SUMMARY
                               (zelfde structuur als Guide)
                            ===================== #}
                            {% if summary %}
                                <div class="mt-5 rounded-lg bg-gray-50 p-4 text-sm space-y-3">

                                    {# PERSONAL ITEM #}
                                    <div class="flex items-center gap-2">
                                        <span>{{ summary.personal.allowed ? '✔️' : '✖️' }}</span>
                                        <span>
                                            Personal item (onder stoel)
                                            {% if summary.personal.dimensionType == 'box' %}
                                                · {{ summary.personal.maxHeightCm }}
                                                × {{ summary.personal.maxWidthCm }}
                                                × {{ summary.personal.maxDepthCm }} cm
                                            {% endif %}
                                        </span>
                                    </div>

                                    {# HANDBAGAGE #}
                                    <div class="flex items-center gap-2">
                                        <span>{{ summary.cabin.allowed ? '✔️' : '✖️' }}</span>
                                        <span>{{ summary.cabin.quantityCabin }} stuks
                                            Handbagage
                                             {% if summary.cabin.dimensionType == 'box' %}
                                                · {{ summary.cabin.maxHeightCm }}
                                                × {{ summary.cabin.maxWidthCm }}
                                                × {{ summary.cabin.maxDepthCm }} cm
                                            {% endif %}
                                        </span>
                                    </div>

                                    {# RUIMBAGAGE #}
                                    {% if summary.hold.allowed %}
                                        <div class="flex items-start gap-2 text-green-700 font-medium">
                                            <span>✔️</span>
                                            <span>{{ summary.hold.quantityCabin }} stuks ruimbagage inbegrepen
                                                {% if summary.hold.dimensionType == 'linear_sum' %}
                                                    · max. {{ summary.hold.maxLinearCm }} cm
                                                {% elseif summary.hold.dimensionType == 'box' %}
                                                    · {{ summary.hold.maxHeightCm }}
                                                    × {{ summary.hold.maxWidthCm }}
                                                    × {{ summary.hold.maxDepthCm }} cm
                                                {% endif %}
                                                {% if summary.hold.maxWeightKg %}
                                                    · {{ summary.hold.maxWeightKg }} kg
                                                {% endif %}
                                            </span>
                                        </div>
                                    {% else %}
                                        <div class="flex items-center gap-2 text-gray-400">
                                            <span>✖️</span>
                                            <span>Geen ruimbagage inbegrepen</span>
                                        </div>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>

                        {# =====================
                           CTA — altijd onderaan
                        ===================== #}
                        <div class="mt-auto pt-6">
                            <a href="{{ path('guide_index', {
                                    transport: 'plane',
                                    airline: airline.slug,
                                    step: 'ticket',
                                    ticket: t.slug
                                }) }}"
                               class="inline-flex items-center justify-center w-full
                                      px-4 py-3 rounded-lg bg-black text-white
                                      text-sm font-medium hover:bg-gray-900 transition">
                                Check dit ticket in de gids →
                            </a>

                            <p class="text-xs text-gray-500 mt-2 text-center">
                                Twijfel? Kies “Ik weet het niet” in de gids.
                            </p>
                        </div>

                    </div>
                {% endif %}
            {% endfor %}
        </div>
    {% endif %}
</section>

{# =========================
   CTA (laatste)
========================= #}
<section class="bg-amber-50 border-t border-amber-200">
    <div class="max-w-7xl mx-auto px-6 py-12 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
            <h3 class="text-xl font-semibold text-gray-900 mb-1">
                Wil je zeker weten wat bij jouw reis past?
            </h3>
            <p class="text-sm text-gray-700 max-w-2xl">
                De duur, bestemming en soort trip bepalen hoeveel ruimte je écht nodig hebt.
                Met de gids krijg je één duidelijke keuze — compact of comfortabel.
            </p>
        </div>

        <a href="{{ path('guide_index', { transport: 'plane', airline: airline.slug }) }}"
           class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-black text-white text-sm font-medium hover:bg-gray-900 transition">
            Start persoonlijk bagage-advies →
        </a>
    </div>
</section>

{# ==========================================================
   FAQ – Airline bagage (SEO + UX, DB-gedreven)
========================================================== #}
{% if faqs is defined and faqs|length > 0 %}
<section class="max-w-5xl mx-auto px-6 py-16">

    <h2 class="text-2xl font-semibold mb-8">
        Veelgestelde vragen over {{ airline.name }} bagage
    </h2>

    <div class="space-y-4">

        {% for faq in faqs %}
            <details class="group rounded-xl border border-gray-200 bg-white p-6">
                <summary
                    class="flex cursor-pointer list-none items-center justify-between
                           font-medium text-gray-900">
                    <span>{{ faq.question }}</span>
                    <span class="transition-transform group-open:rotate-180">⌄</span>
                </summary>

                <div class="mt-4 text-sm text-gray-700 leading-relaxed">
                    {{ faq.answer|raw }}
                </div>
            </details>
        {% endfor %}

    </div>
</section>
{% endif %}

{% endblock %}