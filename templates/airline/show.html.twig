{% extends 'base.html.twig' %}

{% set pageTitle = airline.seoTitle ?: airline.name ~ ' bagageregels | Handbagage en koffers | Topbags' %}
{% set metaDescription = airline.seoDescription ?: 'Bekijk de bagageregels van ' ~ airline.name ~ ' voor personal item, handbagage en ruimbagage. Ontdek welke koffer, rugzak of tas geschikt is.' %}
{% set pageH1 = airline.seoH1 ?: airline.name ~ ' bagageregels: welke tas of koffer mag mee?' %}
{% set canonicalUrl = airline.canonicalUrl ?: 'https://topbags.nl' ~ path('airline_show', { slug: airline.slug }) %}

{% block title %}
    {{ pageTitle }}
{% endblock %}

{% block meta_description %}
    {{ metaDescription }}
{% endblock %}

{% block canonical %}
    <link rel="canonical" href="{{ canonicalUrl|trim }}">
{% endblock %}

{% block robots %}
    {% if airline.isIndexable %}
        <meta name="robots" content="index, follow">
    {% else %}
        <meta name="robots" content="noindex, follow">
    {% endif %}
{% endblock %}

{% block body %}

{# =========================
   HERO
========================= #}
<section class="bg-amber-50 border-b border-amber-200">
    <div class="max-w-7xl mx-auto px-6 py-12 grid md:grid-cols-2 gap-10 items-center">

        <div>
            <div class="inline-flex items-center gap-2 text-amber-700 text-xs font-semibold uppercase tracking-wide">
                <span class="inline-block w-2 h-2 rounded-full bg-amber-500"></span>
                Airline bagagegids
            </div>

            <h1 class="text-3xl md:text-4xl font-semibold text-gray-900 mt-3 mb-4">
                {{ pageH1 }}
            </h1>

            {% if airline.seoIntro %}
                <div class="text-gray-700 max-w-xl leading-7">
                    {{ airline.seoIntro|nl2br }}
                </div>
            {% else %}
                <p class="text-gray-700 max-w-xl leading-7">
                    Vlieg je met {{ airline.name }}? Bekijk welke afmetingen gelden voor personal item,
                    handbagage en ruimbagage. Daarna kun je direct passende koffers en reistassen bekijken
                    of de Bagagegids gebruiken voor persoonlijk advies.
                </p>
            {% endif %}

            <div class="mt-6 flex flex-col sm:flex-row gap-3">
                <a href="{{ path('guide_index', { transport: 'plane', airline: airline.slug }) }}"
                   class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-black text-white text-sm font-medium hover:bg-gray-900 transition">
                    Start persoonlijk bagage-advies →
                </a>

                <a href="#tickets"
                   class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-white border border-gray-300 text-sm font-medium hover:border-black transition">
                    Bekijk ticketregels
                </a>
            </div>

            <p class="text-xs text-gray-500 mt-3">
                Tip: je hebt meestal <strong>één hoofdkeuze</strong> nodig: alleen personal item,
                handbagage of ruimbagage. De gids helpt je kiezen.
            </p>
        </div>

        <div class="flex md:justify-end">
            <div class="bg-white border border-amber-200 rounded-2xl p-6 shadow-sm w-full max-w-md">
                {% if airline.logo %}
                    <img
                        src="{{ asset('images/airline/' ~ airline.logo) }}"
                        alt="{{ airline.name }} logo"
                        class="h-14 w-auto"
                    >
                {% endif %}

                <div class="mt-4 text-sm text-gray-700">
                    Snelle check:
                    <ul class="mt-2 space-y-1 text-gray-600">
                        <li>• Personal item: kleine tas of rugzak onder de stoel</li>
                        <li>• Handbagage: koffer voor in het bagagevak</li>
                        <li>• Ruimbagage: in te checken koffer voor langere reizen</li>
                    </ul>
                </div>

                <a href="#passende-producten"
                   class="mt-5 inline-flex text-sm font-semibold text-amber-700 hover:text-amber-800">
                    Bekijk passende producten →
                </a>
            </div>
        </div>

    </div>
</section>

{# =========================
   ALGEMEEN OVERZICHT
========================= #}
<section class="max-w-7xl mx-auto px-6 py-12">
    <div class="grid md:grid-cols-3 gap-6 items-stretch">

        {# PERSONAL ITEM #}
        <div class="bg-white border border-gray-200 rounded-xl p-6 flex flex-col h-full">
            <div>
                <h2 class="font-semibold text-gray-900 mb-2">
                    Personal item
                </h2>

                <div class="text-sm text-gray-700">
                    Kleine tas, rugzak of underseater die onder de stoel past.
                </div>
            </div>

            {% if fallbackSummary.personal.allowed %}
                <div class="mt-auto pt-4">
                    <div class="inline-flex flex-wrap items-center gap-2 text-sm bg-amber-50 border border-amber-200 rounded-lg px-3 py-2">
                        <span class="text-amber-700 font-semibold">
                            {{ fallbackSummary.personal.maxHeightCm }}
                            x {{ fallbackSummary.personal.maxWidthCm }}
                            x {{ fallbackSummary.personal.maxDepthCm }} cm
                        </span>

                        {% if fallbackSummary.personal.maxWeightKg %}
                            <span class="text-gray-500">
                                · {{ fallbackSummary.personal.maxWeightKg }} kg
                            </span>
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        </div>

        {# HANDBAGAGE #}
        <div class="bg-white border border-gray-200 rounded-xl p-6 flex flex-col h-full">
            <div>
                <h2 class="font-semibold text-gray-900 mb-2">
                    Handbagage
                </h2>

                <div class="text-sm text-gray-700">
                    Handbagagekoffer voor in het bagagevak. Dit hangt vaak af van je ticket of extra optie.
                </div>
            </div>

            {% if fallbackSummary.cabin.allowed %}
                <div class="mt-auto pt-4">
                    <div class="inline-flex flex-wrap items-center gap-2 text-sm bg-amber-50 border border-amber-200 rounded-lg px-3 py-2">
                        <span class="text-amber-700 font-semibold">
                            {{ fallbackSummary.cabin.maxHeightCm }}
                            x {{ fallbackSummary.cabin.maxWidthCm }}
                            x {{ fallbackSummary.cabin.maxDepthCm }} cm
                        </span>

                        {% if fallbackSummary.cabin.maxWeightKg %}
                            <span class="text-gray-500">
                                · {{ fallbackSummary.cabin.maxWeightKg }} kg
                            </span>
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        </div>

        {# RUIMBAGAGE #}
        <div class="bg-white border border-gray-200 rounded-xl p-6 flex flex-col h-full">
            <div>
                <h2 class="font-semibold text-gray-900 mb-2">
                    Ruimbagage
                </h2>

                <div class="text-sm text-gray-700">
                    In te checken bagage. Gewicht en afmetingen hangen af van je ticket of bijgeboekte bagage.
                </div>
            </div>

            {% if fallbackSummary.hold.allowed %}
                <div class="mt-auto pt-4">
                    <div class="inline-flex flex-wrap items-center gap-2 text-sm bg-amber-50 border border-amber-200 rounded-lg px-3 py-2">
                        {% if fallbackSummary.hold.dimensionType == 'linear_sum' %}
                            <span class="text-amber-700 font-semibold">
                                {{ fallbackSummary.hold.maxLinearCm }} cm totaal
                            </span>
                        {% else %}
                            <span class="text-amber-700 font-semibold">
                                {{ fallbackSummary.hold.maxHeightCm }}
                                x {{ fallbackSummary.hold.maxWidthCm }}
                                x {{ fallbackSummary.hold.maxDepthCm }} cm
                            </span>
                        {% endif %}

                        {% if fallbackSummary.hold.maxWeightKg %}
                            <span class="text-gray-500">
                                · {{ fallbackSummary.hold.maxWeightKg }} kg
                            </span>
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        </div>

    </div>

    <div class="mt-8 rounded-xl bg-amber-50 border border-amber-200 p-6">
        <h3 class="font-semibold text-gray-900 mb-2">
            Belangrijk: afmetingen zijn niet het enige
        </h3>

        <p class="text-sm text-gray-700 max-w-3xl leading-6">
            De airline-regels helpen om te bepalen welke tas of koffer mee mag. Wil je ook weten
            hoeveel liter je nodig hebt voor je reisduur, of hoeveel stuks bagage logisch zijn?
            Gebruik dan de Topbags Bagagegids.
        </p>
    </div>
</section>

{# =========================
   TICKETTYPES
========================= #}
<section id="tickets" class="max-w-7xl mx-auto px-6 pb-14">

    {% set ticketTypes = airline.ticketTypes %}

    <div class="flex items-end justify-between gap-6 mb-6">
        <div>
            <h2 class="text-2xl font-semibold text-gray-900">
                {{ airline.name }} tickets en bagage
            </h2>

            <p class="text-gray-600 text-sm max-w-2xl mt-2">
                Je ticket bepaalt wat je mee mag nemen. Hieronder zie je per ticket welke bagage is toegestaan.
            </p>
        </div>

        <a href="{{ path('guide_index', {
                transport: 'plane',
                airline: airline.slug
            }) }}"
           class="hidden md:inline-flex items-center justify-center px-5 py-2.5 rounded-lg bg-black text-white text-sm font-medium hover:bg-gray-900 transition">
            Start de gids →
        </a>
    </div>

    {% if ticketTypes|length == 0 %}
        <p class="text-sm text-gray-500">
            Geen ticketinformatie beschikbaar voor {{ airline.name }}.
        </p>
    {% else %}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {% for t in ticketTypes %}
                {% if t.isActive %}
                    {% set summary = ticketSummaries[t.slug] ?? null %}

                    <div class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-sm transition flex flex-col h-full">

                        <div>
                            <div class="flex items-start justify-between gap-4">
                                <div>
                                    <div class="text-lg font-semibold text-gray-900">
                                        {{ t.name }}
                                    </div>

                                    {% if t.description %}
                                        <div class="text-sm text-gray-600 mt-1">
                                            {{ t.description }}
                                        </div>
                                    {% endif %}
                                </div>

                                <span class="text-xs px-2 py-1 rounded-full bg-amber-100 text-amber-800 font-semibold">
                                    Ticket
                                </span>
                            </div>

                            {% if summary %}
                                <div class="mt-5 rounded-lg bg-gray-50 p-4 text-sm space-y-3">

                                    <div class="flex items-center gap-2 text-green-700 font-medium">
                                        <span>{{ summary.personal.allowed ? '✔️' : '✖️' }}</span>
                                        <span>
                                            Personal item
                                            {% if summary.personal.allowed and summary.personal.dimensionType == 'box' %}
                                                · {{ summary.personal.maxHeightCm }}
                                                x {{ summary.personal.maxWidthCm }}
                                                x {{ summary.personal.maxDepthCm }} cm
                                            {% endif %}
                                        </span>
                                    </div>

                                    {# HANDBAGAGE #}
                                    {% if summary.cabin.allowed %}
                                        <div class="flex items-start gap-2 text-green-700 font-medium">
                                            <span>✔️</span>
                                            <span>
                                                Handbagage toegestaan

                                                {% if summary.cabin.quantityCabin %}
                                                    · {{ summary.cabin.quantityCabin }} stuk(s)
                                                {% endif %}

                                                {% if summary.cabin.dimensionType == 'linear_sum' %}
                                                    · max. {{ summary.cabin.maxLinearCm }} cm
                                                {% elseif summary.cabin.dimensionType == 'box' %}
                                                    · {{ summary.cabin.maxHeightCm }}
                                                    x {{ summary.cabin.maxWidthCm }}
                                                    x {{ summary.cabin.maxDepthCm }} cm
                                                {% endif %}

                                                {% if summary.cabin.maxWeightKg %}
                                                    · {{ summary.cabin.maxWeightKg }} kg
                                                {% endif %}
                                            </span>
                                        </div>
                                    {% else %}
                                        <div class="flex items-start gap-2 text-gray-500">
                                            <span>✖️</span>
                                            <span>
                                                Handbagage

                                                {% if summary.cabin.dimensionType == 'linear_sum' and summary.cabin.maxLinearCm %}
                                                     bij te boeken tot max. {{ summary.cabin.maxLinearCm }} cm
                                                {% elseif summary.cabin.dimensionType == 'box'
                                                    and summary.cabin.maxHeightCm
                                                    and summary.cabin.maxWidthCm
                                                    and summary.cabin.maxDepthCm
                                                %}
                                                     bij te boeken tot max. {{ summary.cabin.maxHeightCm }}
                                                    x {{ summary.cabin.maxWidthCm }}
                                                    x {{ summary.cabin.maxDepthCm }} cm
                                                {% endif %}

                                                {% if summary.cabin.maxWeightKg %}
                                                    · {{ summary.cabin.maxWeightKg }} kg
                                                {% endif %}
                                            </span>
                                        </div>
                                    {% endif %}

                                    {# RUIMBAGAGE #}
                                    {% if summary.hold.allowed %}
                                        <div class="flex items-start gap-2 text-green-700 font-medium">
                                            <span>✔️</span>
                                            <span>
                                                Ruimbagage toegestaan
                                                {% if summary.hold.quantityHold is defined and summary.hold.quantityHold %}
                                                    · {{ summary.hold.quantityHold }} stuk(s)
                                                {% elseif summary.hold.quantityCabin is defined and summary.hold.quantityCabin %}
                                                    · {{ summary.hold.quantityCabin }} stuk(s)
                                                {% endif %}

                                                {% if summary.hold.dimensionType == 'linear_sum' %}
                                                    · max. {{ summary.hold.maxLinearCm }} cm
                                                {% elseif summary.hold.dimensionType == 'box' %}
                                                    · {{ summary.hold.maxHeightCm }}
                                                    x {{ summary.hold.maxWidthCm }}
                                                    x {{ summary.hold.maxDepthCm }} cm
                                                {% endif %}

                                                {% if summary.hold.maxWeightKg %}
                                                    · {{ summary.hold.maxWeightKg }} kg
                                                {% endif %}
                                            </span>
                                        </div>
                                    {% else %}
                                        <div class="flex items-center gap-2 text-gray-400">
                                            <span>✖️</span>
                                            <span>Geen ruimbagage inbegrepen</span>
                                        </div>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>

                        <div class="mt-auto pt-6">
                            <a href="{{ path('guide_index', {
                                    transport: 'plane',
                                    airline: airline.slug,
                                    step: 'ticket',
                                    ticket: t.slug
                                }) }}"
                               class="inline-flex items-center justify-center w-full px-4 py-3 rounded-lg bg-black text-white text-sm font-medium hover:bg-gray-900 transition">
                                Check dit ticket in de gids →
                            </a>

                            <p class="text-xs text-gray-500 mt-2 text-center">
                                Twijfel? Kies “Ik weet het niet” in de gids.
                            </p>
                        </div>

                    </div>
                {% endif %}
            {% endfor %}
        </div>
    {% endif %}
</section>

{# =========================
   CTA GIDS
========================= #}
<section class="bg-amber-50 border-y border-amber-200">
    <div class="max-w-7xl mx-auto px-6 py-12 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
            <h3 class="text-xl font-semibold text-gray-900 mb-1">
                Wil je zeker weten wat bij jouw reis past?
            </h3>

            <p class="text-sm text-gray-700 max-w-2xl leading-6">
                De duur, bestemming en soort trip bepalen hoeveel ruimte je echt nodig hebt.
                Met de gids krijg je één duidelijke keuze: compact of comfortabel.
            </p>
        </div>

        <a href="{{ path('guide_index', { transport: 'plane', airline: airline.slug }) }}"
           class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-black text-white text-sm font-medium hover:bg-gray-900 transition">
            Start persoonlijk bagage-advies →
        </a>
    </div>
</section>

{# =========================
   PASSENDE PRODUCTEN
========================= #}
<section id="passende-producten" class="bg-white">
    {% include 'airline/_product_rail.html.twig' with {
        title: 'Personal item voor ' ~ airline.name,
        description: 'Kleine tassen, rugzakken en underseaters die geschikt zijn voor reizen met alleen een persoonlijk item.',
        items: personalItems,
        ctaUrl: path('shop_all') ~ '?airline[]=' ~ airline.slug ~ '&scope=personal',
        ctaLabel: 'Alle personal items bekijken →'
    } only %}

    {% include 'airline/_product_rail.html.twig' with {
        title: 'Handbagage voor ' ~ airline.name,
        description: 'Handbagagekoffers en cabintrolleys die passen binnen de bagageregels van deze luchtvaartmaatschappij.',
        items: cabinItems,
        ctaUrl: path('shop_all') ~ '?airline[]=' ~ airline.slug ~ '&scope=cabin',
        ctaLabel: 'Alle handbagage bekijken →'
    } only %}

    {% include 'airline/_product_rail.html.twig' with {
        title: 'Ruimbagage voor ' ~ airline.name,
        description: 'Ruime koffers voor zonvakanties, verre reizen en langere verblijven.',
        items: holdItems,
        ctaUrl: path('shop_all') ~ '?airline[]=' ~ airline.slug ~ '&scope=hold',
        ctaLabel: 'Alle ruimbagage bekijken →'
    } only %}
</section>

{# =========================
   FAQ
========================= #}
{% if faqs is defined and faqs|length > 0 %}
    <section class="max-w-5xl mx-auto px-6 py-16">
        <h2 class="text-2xl font-semibold mb-8">
            Veelgestelde vragen over {{ airline.name }} bagage
        </h2>

        <div class="space-y-4">
            {% for faq in faqs %}
                <details class="group rounded-xl border border-gray-200 bg-white p-6">
                    <summary class="flex cursor-pointer list-none items-center justify-between font-medium text-gray-900">
                        <span>{{ faq.question }}</span>
                        <span class="transition-transform group-open:rotate-180">⌄</span>
                    </summary>

                    <div class="mt-4 text-sm text-gray-700 leading-relaxed">
                        {{ faq.answer|nl2br }}
                    </div>
                </details>
            {% endfor %}
        </div>
    </section>
{% endif %}

{% endblock %}