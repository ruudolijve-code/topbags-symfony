{% extends 'base.html.twig' %}

{% block title %}Vliegmaatschappijen bagageregels | Handbagage & koffers | Topbags{% endblock %}

{% block meta_description %}Bekijk per vliegmaatschappij de bagageregels voor handbagage, personal item en ruimbagage. Check welke koffer of tas past bij jouw vlucht.{% endblock %}

{% block body %}

<section class="bg-amber-50 border-b border-amber-200">
    <div class="max-w-7xl mx-auto px-6 py-12">
        <div class="inline-flex items-center gap-2 text-amber-700 text-xs font-semibold uppercase tracking-wide">
            <span class="inline-block w-2 h-2 rounded-full bg-amber-500"></span>
            Bagagegids per airline
        </div>

        <h1 class="text-3xl md:text-4xl font-semibold text-gray-900 mt-3 mb-3">
            Vliegmaatschappijen bagageregels
        </h1>

        <p class="text-gray-700 max-w-2xl leading-7">
            Kies je vliegmaatschappij en bekijk direct welke regels gelden voor je personal item,
            handbagagekoffer en ruimbagage. Daarna kun je met onze Bagagegids in 1 minuut bepalen
            welke tas of koffer het beste bij jouw reis past.
        </p>
    </div>
</section>

<section class="max-w-7xl mx-auto px-6 py-12">
    <div class="mb-8">
        <h2 class="text-2xl font-semibold text-gray-900">
            Check de handbagage regels per vliegmaatschappij
        </h2>

        <p class="mt-2 text-sm text-gray-600 max-w-3xl leading-6">
            De afmetingen voor handbagage verschillen per airline. Controleer daarom vooraf of je rugzak,
            underseater, trolley of koffer voldoet aan de regels van je vlucht.
        </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

        {% for a in airlines %}
            <a href="{{ path('airline_show', { slug: a.getSlug() }) }}"
               class="group bg-white border border-gray-200 rounded-xl p-6 hover:shadow-md hover:border-amber-300 transition block">

                <div class="flex items-center gap-4">

                    {# LOGO BOX – alles gelijk trekken #}
                    <div class="w-20 h-12 flex items-center justify-center shrink-0">

                        {% set logo = a.getLogo() %}
                        {% if logo %}
                            <img
                                src="{{ asset('images/airline/' ~ logo) }}"
                                alt="{{ a.getName() }} logo"
                                class="w-full h-full object-contain"
                                loading="lazy"
                            >
                        {% else %}
                            <span class="text-xs text-gray-400">
                                {{ a.getName() }}
                            </span>
                        {% endif %}
                    </div>

                    {# Tekst #}
                    <div class="min-w-0">
                        <div class="font-semibold text-gray-900">
                            {{ a.getName() }}
                        </div>

                        {% if a.getHint() %}
                            <div class="text-sm text-gray-500 leading-5">
                                {{ a.getHint() }}
                            </div>
                        {% endif %}
                    </div>

                </div>

                <div class="mt-5 border-t border-gray-100 pt-4">
                    <div class="text-sm font-semibold text-amber-700 group-hover:text-amber-800">
                        Welke koffer mag mee bij {{ a.getName() }}?
                    </div>

                    <div class="mt-1 text-xs text-gray-500">
                        Bekijk personal item, handbagage en ruimbagage.
                    </div>
                </div>

            </a>
        {% endfor %}

    </div>
</section>

{% endblock %}