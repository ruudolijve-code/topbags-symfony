{% extends 'base.html.twig' %}

{% block title %}Kofferhotel – Topbags / Holtkamp{% endblock %}

{% block body %}
<section class="max-w-4xl mx-auto px-6 py-12">

    <header class="mb-10 text-center">
        <h1 class="text-4xl font-bold text-gray-900">Kofferhotel</h1>
        <p class="text-lg text-gray-600 mt-2">Geen opbergruimte? Wij regelen het.</p>
    </header>

    <ul class="space-y-3 bg-gray-50 p-6 rounded-lg shadow-sm">
        <li class="flex items-start"><span class="font-semibold mr-2">•</span>Wij slaan jouw koffers veilig op</li>
        <li class="flex items-start"><span class="font-semibold mr-2">•</span>We zorgen dat je koffers schoon zijn als je op reis gaat</li>
        <li class="flex items-start"><span class="font-semibold mr-2">•</span>Voor vertrek controleren we alle onderdelen</li>
        <li class="flex items-start"><span class="font-semibold mr-2">•</span>Zelfde principe als het opslaan van winterbanden</li>
    </ul>

    <section class="mt-12">
        <h2 class="text-2xl font-semibold text-gray-900 mb-6 text-center">Hoe werkt het kofferhotel?</h2>

        <div class="grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-5 gap-6 text-center">
            <div class="p-4 bg-white shadow rounded">Kies jouw koffer</div>
            <div class="p-4 bg-white shadow rounded">Kies uw leverdatum</div>
            <div class="p-4 bg-white shadow rounded">U haalt de koffer</div>
            <div class="p-4 bg-white shadow rounded">Ga zorgeloos op reis</div>
            <div class="p-4 bg-white shadow rounded">U brengt de koffer</div>
        </div>
    </section>

    <section class="mt-12 text-center">
        <h2 class="text-2xl font-semibold text-gray-900 mb-4">Opslag reserveren</h2>
        <p class="text-lg">
            Bel: <strong>074-291 2205</strong><br>
            of mail naar
            <a href="mailto:koffer-huren@topbags.nl" class="text-blue-600 underline">koffer-huren@topbags.nl</a>
        </p>
    </section>

</section>
{% endblock %}



