{% extends 'base.html.twig' %}

{% block title %}Topbags – Koffers, reistassen en slim reisadvies{% endblock %}

{% block body %}
<!-- DEBUG GA ID: {{ ga4_measurement_id|default('LEEG') }} -->
{# =========================================
   1. HERO
   ========================================= #}
<section class="border-b border-gray-200 bg-[#f7f4ee]">
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-6 py-16 lg:grid-cols-2 lg:py-24">

        <div class="max-w-xl">
            <div class="inline-flex items-center rounded-full bg-white px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-gray-600 shadow-sm">
                Specialist in koffers & reistassen
            </div>

            <h1 class="mt-6 text-4xl font-semibold leading-tight tracking-tight text-gray-900 lg:text-6xl">
                Vind de juiste bagage voor jouw reis
            </h1>

            <p class="mt-6 text-lg leading-relaxed text-gray-600">
                Van handbagage tot ruime koffers en lichte reistassen.
                Kies direct uit onze collectie of laat je helpen door de bagagegids.
            </p>

            <div class="mt-8 flex flex-wrap gap-4">
                <a href="{{ path('guide_index') }}"
                   class="inline-flex items-center rounded-full bg-black px-6 py-3 text-sm font-semibold text-white transition hover:bg-gray-900">
                    Start de bagagegids
                </a>

                <a href="{{ path('category_show', { slug: 'koffers' }) }}"
                   class="inline-flex items-center rounded-full border border-gray-300 px-6 py-3 text-sm font-semibold text-gray-900 transition hover:bg-white">
                    Shop koffers
                </a>
            </div>

            <div class="mt-8 flex flex-wrap gap-6 text-sm text-gray-500">
                <span>Officieel dealer</span>
                <span>30 dagen retour</span>
                <span>Familiebedrijf sinds 1900</span>
            </div>
        </div>

        <div class="relative">
            <div class="overflow-hidden rounded-[2rem] bg-white shadow-xl">
                <img
                    src="{{ asset('images/home/hero-travel.jpg') }}"
                    alt="Koffers en reistassen van Topbags"
                    class="h-[470px] w-full object-cover lg:h-[590px]"
                >
            </div>
        </div>

    </div>
</section>

{# =========================================
   2. CATEGORIE INGANGEN
   ========================================= #}
<section class="bg-white py-14 lg:py-18">
    <div class="mx-auto max-w-7xl px-6">
        <div class="mb-8">
            <h2 class="text-2xl font-semibold text-gray-900">Shop per categorie</h2>
            <p class="mt-2 text-gray-600">Snel naar de juiste bagage voor jouw reisstijl.</p>
        </div>

        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-4">
            <a href="{{ path('category_show', { slug: 'koffers' }) }}"
               class="group overflow-hidden rounded-3xl border border-gray-200 bg-white transition hover:-translate-y-1 hover:shadow-lg">
                <div class="aspect-[4/5] overflow-hidden bg-gray-50">
                    <img src="{{ asset('images/home/koffer.jpg') }}"
                         alt="Koffers"
                         class="h-full w-full object-cover transition duration-500 group-hover:scale-105">
                </div>
                <div class="p-6">
                    <h3 class="text-xl font-semibold text-gray-900">Koffers</h3>
                    <p class="mt-2 text-sm text-gray-600">Voor weekendtrips, vakanties en verre reizen.</p>
                </div>
            </a>

            <a href="{{ path('category_show', { slug: 'reistassen' }) }}"
               class="group overflow-hidden rounded-3xl border border-gray-200 bg-white transition hover:-translate-y-1 hover:shadow-lg">
                <div class="aspect-[4/5] overflow-hidden bg-gray-50">
                    <img src="{{ asset('images/home/reistas.jpg') }}"
                         alt="Reistassen"
                         class="h-full w-full object-cover transition duration-500 group-hover:scale-105">
                </div>
                <div class="p-6">
                    <h3 class="text-xl font-semibold text-gray-900">Reistassen</h3>
                    <p class="mt-2 text-sm text-gray-600">Licht, flexibel en praktisch onderweg.</p>
                </div>
            </a>

            <a href="{{ path('category_show', { slug: 'handbagage' }) }}"
               class="group overflow-hidden rounded-3xl border border-gray-200 bg-white transition hover:-translate-y-1 hover:shadow-lg">
                <div class="aspect-[4/5] overflow-hidden bg-gray-50">
                    <img src="{{ asset('images/home/rugzak.jpg') }}"
                         alt="Handbagage"
                         class="h-full w-full object-cover transition duration-500 group-hover:scale-105">
                </div>
                <div class="p-6">
                    <h3 class="text-xl font-semibold text-gray-900">Handbagage</h3>
                    <p class="mt-2 text-sm text-gray-600">Compact, slim en geschikt voor cabinegebruik.</p>
                </div>
            </a>

            <a href="{{ path('bags_index') }}"
               class="group overflow-hidden rounded-3xl border border-gray-200 bg-white transition hover:-translate-y-1 hover:shadow-lg">
                <div class="aspect-[4/5] overflow-hidden bg-gray-50">
                    <img src="{{ asset('images/home/damestas.png') }}"
                         alt="Damestassen"
                         class="h-full w-full object-cover transition duration-500 group-hover:scale-105">
                </div>
                <div class="p-6">
                    <h3 class="text-xl font-semibold text-gray-900">Damestassen</h3>
                    <p class="mt-2 text-sm text-gray-600">Stijlvolle tassen voor dagelijks gebruik en onderweg.</p>
                </div>
            </a>
        </div>
    </div>
</section>

{# =========================================
   3. BAGAGEGIDS
   ========================================= #}
<section class="bg-[#f7f4ee] py-16 lg:py-20">
    <div class="mx-auto grid max-w-7xl items-center gap-10 px-6 lg:grid-cols-2">
        <div>
            <div class="text-xs font-semibold uppercase tracking-[0.18em] text-gray-500">
                Bagagegids
            </div>
            <h2 class="mt-3 text-3xl font-semibold tracking-tight text-gray-900">
                Twijfel je welke koffer of tas past bij jouw reis?
            </h2>
            <p class="mt-4 max-w-xl text-base leading-relaxed text-gray-600">
                Beantwoord een paar vragen over je reis, vervoer en voorkeuren.
                Daarna laten we direct zien welke bagage het beste past.
            </p>

            <div class="mt-8 flex flex-wrap gap-4">
                <a href="{{ path('guide_index') }}"
                   class="inline-flex items-center rounded-full bg-black px-6 py-3 text-sm font-semibold text-white transition hover:bg-gray-900">
                    Start de gids
                </a>

                <a href="{{ path('shop_index') }}"
                   class="inline-flex items-center rounded-full border border-gray-300 px-6 py-3 text-sm font-semibold text-gray-900 transition hover:bg-white">
                    Bekijk collectie
                </a>
            </div>
        </div>

        <div class="overflow-hidden rounded-[2rem] bg-white shadow-xl">
            <img
                src="{{ asset('images/home/hero.jpg') }}"
                alt="Bagagegids van Topbags"
                class="h-[320px] w-full object-cover lg:h-[420px]"
            >
        </div>
    </div>
</section>

{# =========================================
   4. POPULAIRE KOFFERS
   ========================================= #}
<section class="bg-white py-16 lg:py-20">
    <div class="mx-auto max-w-7xl px-6">
        <div class="mb-8 flex items-end justify-between gap-6">
            <div>
                <h2 class="text-2xl font-semibold text-gray-900">Populaire koffers</h2>
                <p class="mt-2 text-gray-600">Veelgekozen modellen voor citytrips, vakanties en verre reizen.</p>
            </div>

            <a href="{{ path('category_show', { slug: 'koffers' }) }}"
               class="hidden text-sm font-semibold text-gray-700 transition hover:text-black lg:inline">
                Bekijk alle koffers →
            </a>
        </div>

        {% if featuredSuitcases is defined and featuredSuitcases is not empty %}
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
                {% for item in featuredSuitcases %}
                    {% include 'shop/component/card/_card_functional.html.twig' with {
                        product: item.product,
                        variant: item.variant,
                        master: item.master,
                        mediaPath: item.mediaPath,
                        availability: item.availability
                    } only %}
                {% endfor %}
            </div>
        {% else %}
            <div class="rounded-2xl border border-dashed border-gray-300 p-8 text-sm text-gray-400">
                Nog geen uitgelichte koffers beschikbaar.
            </div>
        {% endif %}
    </div>
</section>

{# =========================================
   5. MERKENBLOKKEN
   ========================================= #}
<section class="bg-white pb-16 lg:pb-20">
    <div class="mx-auto max-w-7xl px-6">
        <div class="mb-8">
            <h2 class="text-2xl font-semibold text-gray-900">Shop per merk</h2>
            <p class="mt-2 text-gray-600">Ontdek collecties van toonaangevende bagagemerken.</p>
        </div>

        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-4">
            <a href="/merk/samsonite" class="rounded-3xl border border-gray-200 bg-white p-8 transition hover:shadow-lg">
                <h3 class="text-xl font-semibold text-gray-900">Samsonite</h3>
                <p class="mt-3 text-sm leading-relaxed text-gray-600">
                    Innovatieve koffers en reisoplossingen voor intensief gebruik.
                </p>
            </a>

            <a href="/merk/delsey" class="rounded-3xl border border-gray-200 bg-white p-8 transition hover:shadow-lg">
                <h3 class="text-xl font-semibold text-gray-900">Delsey</h3>
                <p class="mt-3 text-sm leading-relaxed text-gray-600">
                    Franse elegantie met focus op lichtgewicht en comfort.
                </p>
            </a>

            <a href="/merk/cabinzero" class="rounded-3xl border border-gray-200 bg-white p-8 transition hover:shadow-lg">
                <h3 class="text-xl font-semibold text-gray-900">CabinZero</h3>
                <p class="mt-3 text-sm leading-relaxed text-gray-600">
                    Slimme, lichte tassen en rugzakken voor cabine- en citytrips.
                </p>
            </a>

            <a href="{{ path('shop_index') }}" class="rounded-3xl border border-gray-200 bg-white p-8 transition hover:shadow-lg">
                <h3 class="text-xl font-semibold text-gray-900">Alle merken</h3>
                <p class="mt-3 text-sm leading-relaxed text-gray-600">
                    Bekijk de volledige collectie met premium en praktische reismerken.
                </p>
            </a>
        </div>
    </div>
</section>

{# =========================================
   6. REISTASSEN / DAMESTASSEN SPOTLIGHT
   ========================================= #}
<section class="bg-[#f7f4ee] py-16 lg:py-20">
    <div class="mx-auto grid max-w-7xl gap-6 px-6 lg:grid-cols-2">
        <a href="{{ path('category_show', { slug: 'reistassen' }) }}"
           class="group overflow-hidden rounded-[2rem] bg-white shadow-sm transition hover:shadow-xl">
            <div class="aspect-[12/10] overflow-hidden">
                <img src="{{ asset('images/home/spotlight-reistassen.jpg') }}"
                     alt="Reistassen"
                     class="h-full w-full object-cover transition duration-500 group-hover:scale-105">
            </div>
            <div class="p-8">
                <h3 class="text-2xl font-semibold text-gray-900">Reistassen voor flexibel reizen</h3>
                <p class="mt-3 text-sm leading-relaxed text-gray-600">
                    Kies voor licht, ruim en praktisch. Ideaal voor auto, trein of korte vliegreizen.
                </p>
            </div>
        </a>

        <a href="{{ path('bags_index') }}"
           class="group overflow-hidden rounded-[2rem] bg-white shadow-sm transition hover:shadow-xl">
            <div class="aspect-[12/10] overflow-hidden">
                <img src="{{ asset('images/home/spotlight-damestassen.jpg') }}"
                     alt="Damestassen"
                     class="h-full w-full object-cover transition duration-500 group-hover:scale-105">
            </div>
            <div class="p-8">
                <h3 class="text-2xl font-semibold text-gray-900">Damestassen voor werk en onderweg</h3>
                <p class="mt-3 text-sm leading-relaxed text-gray-600">
                    Van stijlvolle schoudertas tot praktische dagelijkse favoriet.
                </p>
            </div>
        </a>
    </div>
</section>

{# =========================================
   7. UITGELICHTE REISTASSEN
   ========================================= #}
<section class="bg-white py-16 lg:py-20">
    <div class="mx-auto max-w-7xl px-6">
        <div class="mb-8 flex items-end justify-between gap-6">
            <div>
                <h2 class="text-2xl font-semibold text-gray-900">Uitgelichte reistassen</h2>
                <p class="mt-2 text-gray-600">Licht, praktisch en klaar voor vertrek.</p>
            </div>

            <a href="{{ path('category_show', { slug: 'reistassen' }) }}"
               class="hidden text-sm font-semibold text-gray-700 transition hover:text-black lg:inline">
                Bekijk alle reistassen →
            </a>
        </div>

        {% if featuredTravelBags is defined and featuredTravelBags is not empty %}
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
                {% for item in featuredTravelBags %}
                    {% include 'shop/component/card/_card_functional.html.twig' with {
                        product: item.product,
                        variant: item.variant,
                        master: item.master,
                        mediaPath: item.mediaPath,
                        availability: item.availability
                    } only %}
                {% endfor %}
            </div>
        {% else %}
            <div class="rounded-2xl border border-dashed border-gray-300 p-8 text-sm text-gray-400">
                Nog geen uitgelichte reistassen beschikbaar.
            </div>
        {% endif %}
    </div>
</section>

{# =========================================
   8. TRUST / VERHAAL
   ========================================= #}
<section class="bg-white py-16 lg:py-20">
    <div class="mx-auto max-w-5xl px-6">
        <div class="rounded-[2rem] border border-gray-200 bg-white p-8 shadow-sm lg:p-12">
            <h2 class="text-2xl font-semibold text-gray-900 lg:text-3xl">
                Topbags – specialist in koffers, reistassen en slimme bagagekeuzes
            </h2>

            <div class="mt-6 space-y-4 text-base leading-relaxed text-gray-600">
                <p>
                    Bij Topbags helpen we je niet alleen een product te kiezen, maar vooral de juiste bagage voor jouw reis.
                    Of je nu op citytrip gaat, een verre vakantie plant of dagelijks onderweg bent.
                </p>
                <p>
                    Als officieel dealer van sterke merken combineren we kwaliteit, service en praktisch advies.
                    Daarbij kun je ook rekenen op de ervaring van Holtkamp Tassen &amp; Koffers, familiebedrijf sinds 1900.
                </p>
            </div>
        </div>
    </div>
</section>

{% endblock %}