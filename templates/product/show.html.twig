{% extends 'base.html.twig' %}

{% block title %}{{ seoTitle|default(product.name ~ ' | Topbags') }}{% endblock %}

{% block meta_description %}{{ seoDescription|default('Bekijk dit product bij Topbags. Bestel online of kom langs in onze winkel in Hengelo.')|trim }}{% endblock %}

{% block structured_data %}
    {% if productSchema is defined and productSchema %}
        <script type="application/ld+json">
            {{ productSchema|json_encode|raw }}
        </script>
    {% endif %}
{% endblock %}

{% block body %}
    <div class="max-w-[1400px] mx-auto px-6 py-1">
        <nav class="mb-8 text-xs text-gray-500">
            <a href="{{ path('home') }}" class="hover:text-gray-900">Home</a>
            <span class="mx-2">/</span>

            <a href="{{ path('brand_show', { slug: product.brand.slug }) }}" class="hover:text-gray-900">
                {{ product.brand.name }}
            </a>

            <span class="mx-2">/</span>
            <span class="text-gray-900">{{ product.name }}</span>
        </nav>

        {% for message in app.flashes('error') %}
            <div class="mb-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                {{ message }}
            </div>
        {% endfor %}

        {% for message in app.flashes('success') %}
            <div class="mb-4 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
                {{ message }}
            </div>
        {% endfor %}
    </div>

    <section id="product-focus" class="scroll-mt-40">
        {% include 'product/_hero_museum_fullwidth.html.twig' with {
            product: product,
            variant: variant,
            master: master,
            mediaPath: mediaPath,
            imageBasePath: imageBasePath,
            availability: availability
        } %}
    </section>

    <div class="max-w-[1400px] mx-auto px-6">
        {% include 'product/_details.html.twig' %}
    </div>

    {# GA4 - view_item #}
    {% if ga4_measurement_id %}
        <script>
            window.dataLayer = window.dataLayer || [];

            function gtag() {
                dataLayer.push(arguments);
            }

            gtag('event', 'view_item', {
                currency: 'EUR',
                value: {{ variant.displayPrice|default(variant.price)|default(0)|number_format(2, '.', '') }},
                items: [{
                    item_id: '{{ variant.variantSku|e('js') }}',
                    item_name: '{{ product.name|e('js') }}',
                    item_brand: '{{ product.brand ? product.brand.name|e('js') : '' }}',
                    item_category: '{{ product.categories|length > 0 ? product.categories|first.name|e('js') : '' }}',
                    item_variant: '{{ variant.supplierColorName|default('')|e('js') }}',
                    price: {{ variant.displayPrice|default(variant.price)|default(0)|number_format(2, '.', '') }},
                    quantity: 1
                }]
            });
        </script>
    {% endif %}

    {# Meta Pixel - ViewContent voor catalogusmatching #}
    <script>
        if (typeof fbq === 'function') {
            fbq('track', 'ViewContent', {
                content_ids: ['{{ variant.variantSku|e('js') }}'],
                content_type: 'product',
                value: {{ variant.displayPrice|default(variant.price)|default(0)|number_format(2, '.', '') }},
                currency: 'EUR'
            });
        }
    </script>

    {# Correct scrollen naar product-focus bij ankerlink #}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (window.location.hash !== '#product-focus') {
                return;
            }

            const target = document.getElementById('product-focus');

            if (!target) {
                return;
            }

            setTimeout(function () {
                const headerOffset = 90;
                const y = target.getBoundingClientRect().top + window.pageYOffset - headerOffset;

                window.scrollTo({
                    top: y,
                    behavior: 'auto'
                });
            }, 80);
        });
    </script>
{% endblock %}

