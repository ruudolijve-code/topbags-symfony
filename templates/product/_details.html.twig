<section id="details" class="mt-24">
    <div class="grid lg:grid-cols-12 gap-16">

        {# Omschrijving #}
        <div class="lg:col-span-7">
            <h2 class="text-sm tracking-[0.2em] uppercase text-gray-500">
                Omschrijving
            </h2>

            {% if product.description %}
                <div class="mt-6 text-lg leading-relaxed text-gray-900 max-w-2xl">
                    {{ product.description|raw }}
                </div>
            {% endif %}
        </div>

        {# Specificaties + productinformatie #}
        <div class="lg:col-span-5">
            <div x-data="{ specsOpen: true, infoOpen: false }" class="space-y-4">

                {# =========================
                   ACCORDION · SPECIFICATIES
                   ========================= #}
                <div class="border border-gray-200 rounded-2xl overflow-hidden">
                    <button
                        type="button"
                        @click="specsOpen = !specsOpen"
                        class="w-full flex items-center justify-between px-5 py-4 text-left bg-white"
                    >
                        <span class="text-sm tracking-[0.2em] uppercase text-gray-500">
                            Specificaties
                        </span>

                        <svg
                            class="w-5 h-5 text-gray-500 transition-transform duration-200"
                            :class="specsOpen ? 'rotate-180' : ''"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                    </button>

                    <div
                        x-show="specsOpen"
                        x-collapse
                        class="px-5 pb-5"
                    >
                        <ul class="space-y-4 text-sm text-gray-700">

                            {% if product.heightCm %}
                                <li class="flex justify-between gap-6 border-b border-gray-100 pb-2">
                                    <span>Hoogte</span>
                                    <span class="text-right">{{ product.heightCm }} cm</span>
                                </li>
                            {% endif %}

                            {% if product.widthCm %}
                                <li class="flex justify-between gap-6 border-b border-gray-100 pb-2">
                                    <span>Breedte</span>
                                    <span class="text-right">{{ product.widthCm }} cm</span>
                                </li>
                            {% endif %}

                            {% if product.depthCm %}
                                <li class="flex justify-between gap-6 border-b border-gray-100 pb-2">
                                    <span>Diepte</span>
                                    <span class="text-right">{{ product.depthCm }} cm</span>
                                </li>
                            {% endif %}

                            {% if product.volumeL %}
                                <li class="flex justify-between gap-6 border-b border-gray-100 pb-2">
                                    <span>Inhoud</span>
                                    <span class="text-right">{{ product.volumeL }} L</span>
                                </li>
                            {% endif %}

                            {% if product.weightKg %}
                                <li class="flex justify-between gap-6 border-b border-gray-100 pb-2">
                                    <span>Gewicht</span>
                                    <span class="text-right">{{ product.weightKg }} kg</span>
                                </li>
                            {% endif %}

                            {% if product.expandable %}
                                <li class="flex justify-between gap-6 border-b border-gray-100 pb-2">
                                    <span>Uitbreidbaar</span>
                                    <span class="text-right">Ja</span>
                                </li>

                                {% if product.expandableDepthCm %}
                                    <li class="flex justify-between gap-6 border-b border-gray-100 pb-2">
                                        <span>Extra diepte uitgeklapt</span>
                                        <span class="text-right">+ {{ product.expandableDepthCm }} cm</span>
                                    </li>
                                {% endif %}

                                {% if product.expandableVolumeL %}
                                    <li class="flex justify-between gap-6 border-b border-gray-100 pb-2">
                                        <span>Extra inhoud uitgeklapt</span>
                                        <span class="text-right">+ {{ product.expandableVolumeL }} L</span>
                                    </li>
                                {% endif %}
                            {% endif %}

                            {% if product.wheelsCount %}
                                <li class="flex justify-between gap-6 border-b border-gray-100 pb-2">
                                    <span>Aantal wielen</span>
                                    <span class="text-right">{{ product.wheelsCount }}</span>
                                </li>
                            {% endif %}

                            {% if product.lightweightLabel %}
                                <li class="flex justify-between gap-6 border-b border-gray-100 pb-2">
                                    <span>Lichtgewicht</span>
                                    <span class="text-right">
                                        {{ product.lightweightLabel }}
                                        {% if product.weightPerLiter %}
                                            <span class="text-gray-400">({{ product.weightPerLiter }} g/L)</span>
                                        {% endif %}
                                    </span>
                                </li>
                            {% endif %}

                            {% if product.material %}
                                <li class="flex justify-between gap-6 border-b border-gray-100 pb-2">
                                    <span>Materiaal</span>
                                    <span class="text-right">{{ product.material.name }}</span>
                                </li>
                            {% endif %}

                            {% if product.warrantyYears %}
                                <li class="flex justify-between gap-6 border-b border-gray-100 pb-2">
                                    <span>Garantie</span>
                                    <span class="text-right">{{ product.warrantyYears }} jaar</span>
                                </li>
                            {% endif %}

                            {% if product.laptopCompartment %}
                                <li class="flex justify-between gap-6 {% if not product.tsaLock and not product.brand and not product.series and not product.sku and not product.ean %}pb-0{% else %}border-b border-gray-100 pb-2{% endif %}">
                                    <span>Laptopvak</span>
                                    <span class="text-right">{{ product.laptopMaxInch }} inch</span>
                                </li>
                            {% endif %}

                            {% if product.tsaLock %}
                                <li class="flex justify-between gap-6 border-b border-gray-100 pb-2">
                                    <span>TSA-slot</span>
                                    <span class="text-right">Ja</span>
                                </li>
                            {% endif %}
                        </ul>
                    </div>
                </div>

                {# =========================
                   ACCORDION · PRODUCTINFORMATIE
                   ========================= #}
                <div class="border border-gray-200 rounded-2xl overflow-hidden">
                    <button
                        type="button"
                        @click="infoOpen = !infoOpen"
                        class="w-full flex items-center justify-between px-5 py-4 text-left bg-white"
                    >
                        <span class="text-sm tracking-[0.2em] uppercase text-gray-500">
                            Productinformatie
                        </span>

                        <svg
                            class="w-5 h-5 text-gray-500 transition-transform duration-200"
                            :class="infoOpen ? 'rotate-180' : ''"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                    </button>

                    <div
                        x-show="infoOpen"
                        x-collapse
                        class="px-5 pb-5"
                    >
                        <ul class="space-y-4 text-sm text-gray-700">

                            {% if variant.variantSku %}
                                <li class="flex justify-between gap-6 border-b border-gray-100 pb-2">
                                    <span>SKU</span>
                                    <span class="text-right">{{ variant.variantSku }}</span>
                                </li>
                            {% endif %}

                            {% if variant.ean %}
                                <li class="flex justify-between gap-6 border-b border-gray-100 pb-2">
                                    <span>EAN</span>
                                    <span class="text-right">{{ variant.ean }}</span>
                                </li>
                            {% endif %}

                            {% if product.series %}
                                <li class="flex justify-between gap-6 border-b border-gray-100 pb-2">
                                    <span>Serie</span>
                                    <span class="text-right">{{ product.series }}</span>
                                </li>
                            {% endif %}

                            {% if product.brand %}
                                <li class="flex justify-between gap-6 pb-0">
                                    <span>Merk</span>
                                    <span class="text-right">
                                        {{ product.brand.name ?? product.brand }}
                                    </span>
                                </li>
                            {% endif %}

                        </ul>
                    </div>
                </div>

            </div>
        </div>

    </div>
</section>