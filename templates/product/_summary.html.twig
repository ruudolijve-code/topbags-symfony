<aside class="lg:col-span-4 lg:sticky lg:top-12">
  <div class="max-w-sm">

    {% set displayPrice = variant.displayPrice %}
    {% set regularPrice = variant.price %}
    {% set compareAtPrice = variant.compareAtPrice %}
    {% set saleActive = variant.saleActive %}
    {% set saleBadge = variant.discountBadge %}

    <div class="text-[11px] tracking-[0.2em] uppercase text-gray-500">
      {{ product.brand.name }}
    </div>

    <h1 class="mt-3 text-3xl font-semibold tracking-tight text-gray-900">
      {{ product.name }}
    </h1>

    <div class="mt-2 text-sm text-gray-600">
      {{ variant.supplierColorName }}
      {% if product.material %} · {{ product.material.name }}{% endif %}
    </div>

    {% if displayPrice %}
      <div class="mt-6">
        {% if saleActive and saleBadge %}
          <div class="mb-3">
            <span class="badge-sale">
              {{ saleBadge }}
            </span>
          </div>
        {% endif %}

        <div class="flex flex-wrap items-baseline gap-3">
          <span class="text-3xl font-semibold {{ saleActive ? 'text-red-600' : 'text-gray-900' }}">
            € {{ displayPrice|number_format(2, ',', '.') }}
          </span>
{{ dump(variant.price, variant.displayPrice, variant.saleActive, variant.discountBadge, variant.salePercentage) }}
          {% if saleActive %}
            <span class="text-lg text-gray-500 line-through">
              € {{ regularPrice|number_format(2, ',', '.') }}
            </span>
          {% elseif compareAtPrice and compareAtPrice > displayPrice %}
            <span class="text-base text-gray-500">
              adviesprijs
              <span class="line-through">
                € {{ compareAtPrice|number_format(2, ',', '.') }}
              </span>
            </span>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {# Swatches #}
    {% if colorVariants|length > 0 %}
      <div class="mt-8">
        <div class="text-[11px] tracking-[0.2em] uppercase text-gray-500">
          Kleur
        </div>

        <div class="mt-3 flex gap-3">
          {% for v in colorVariants|slice(0,6) %}
            {% set isCurrent = (v.variantSku == variant.variantSku) %}
            <a href="{{ path('product_show', {
              slug: product.slug,
              colorSlug: v.supplierColorSlug,
              variantSku: v.variantSku
            }) }}"
               class="group">

              <span class="block w-7 h-7 rounded-full border border-gray-300
                {{ isCurrent ? 'ring-2 ring-gray-900 ring-offset-2' : 'group-hover:ring-2 group-hover:ring-gray-400 group-hover:ring-offset-2' }}"
                style="background-color: {{ v.color.hex ?? '#ddd' }}">
              </span>

            </a>
          {% endfor %}
        </div>

        <div class="mt-2 text-xs text-gray-600">
          {{ variant.supplierColorName }}
        </div>
      </div>
    {% endif %}

    {# CTA #}
    <div class="mt-10">
      <button
        class="w-full rounded-full border border-gray-900/20
               px-6 py-3 text-sm font-semibold text-gray-900
               hover:bg-gray-900 hover:text-white transition">
        Winkelwagen
      </button>
    </div>

    {# Service subtiel #}
    <div class="mt-6 text-xs text-gray-500 leading-relaxed">
      Officieel dealer · 30 dagen retour · Familiebedrijf sinds 1900sfgjghegdj
    </div>

  </div>
</aside>