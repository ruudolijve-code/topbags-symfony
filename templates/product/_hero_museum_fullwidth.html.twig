{% set colorVariants = product.variants|filter(v => v.isActive and v.color and v.supplierColorSlug) %}

{% set displayPrice = variant.displayPrice %}
{% set regularPrice = variant.price %}
{% set compareAtPrice = variant.compareAtPrice %}
{% set saleActive = variant.saleActive %}
{% set saleBadge = variant.discountBadge %}

<div class="w-screen relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] bg-[#f4f1ea]">
    {% include 'product/_gallery_dual_museum.html.twig' with {
        product: product,
        variant: variant,
        mediaPath: mediaPath,
        imageBasePath: imageBasePath
    } %}
</div>

<div class="w-screen relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] bg-[#f4f1ea] py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-6">
        <div class="flex flex-col gap-8 lg:flex-row lg:items-start">

            <div class="w-full max-w-xl shrink-0 bg-white p-6 shadow-sm lg:p-8">
                {% if product.brand %}
                    <div class="text-xs tracking-[0.18em] uppercase text-gray-500">
                        {{ product.brand.name }}
                    </div>
                {% endif %}

                <h1 class="mt-3 text-2xl font-semibold text-gray-900 lg:text-3xl">
                    {{ product.name }}

                    {% if variant.supplierColorName %}
                        {{ variant.supplierColorName }}
                    {% endif %}
                </h1>

                {% set productDisplayName = (
                    (product.brand ? product.brand.name ~ ' ' : '')
                    ~ product.name
                )|trim %}

                {% if variant.seoDescription %}
                    <p class="mt-4 text-sm leading-6 text-gray-700">
                        {{ variant.seoDescription }}
                    </p>
                {% else %}
                    <p class="mt-4 text-sm leading-6 text-gray-700">
                        Ontdek de {{ productDisplayName }}{% if variant.supplierColorName %} in de kleur {{ variant.supplierColorName }}{% endif %}.
                        Bestel eenvoudig online bij Topbags of bekijk het model in onze winkel in Hengelo.
                    </p>
                {% endif %}

                {% if product.material %}
                    <div class="mt-2 text-sm text-gray-600">
                        Materiaal: {{ product.material.name }}
                    </div>
                {% endif %}

                {% if colorVariants|length > 1 %}
                    <div class="mt-6">
                        <div class="text-xs tracking-[0.18em] uppercase text-gray-500">
                            Kleur
                        </div>

                        <div class="mt-3 flex flex-wrap gap-3">
                            {% for v in colorVariants %}
                                <a href="{{ path('product_show', {
                                    slug: product.slug,
                                    colorSlug: v.supplierColorSlug,
                                    variantSku: v.variantSku
                                }) }}#product-focus"
                                   class="w-7 h-7 rounded-full border {{ v.variantSku == variant.variantSku ? 'ring-2 ring-black ring-offset-2' : '' }}"
                                   style="background-color: {{ v.color.hex }}"
                                   aria-label="{{ v.supplierColorName }}">
                                </a>
                            {% endfor %}
                        </div>

                        <div class="mt-2 text-xs text-gray-600">
                            Klik op een andere kleur om deze te bekijken.
                        </div>
                    </div>
                {% endif %}

                {% if displayPrice %}
                    <div class="mt-6">
                        {% if saleActive and saleBadge %}
                            <div class="mb-3">
                                <span class="badge-sale">
                                    {{ saleBadge }}
                                </span>
                            </div>
                        {% endif %}

                        <div class="flex flex-wrap items-baseline gap-3">
                            <span class="text-xl font-semibold {{ saleActive ? 'text-red-600' : 'text-gray-900' }}">
                                € {{ displayPrice|number_format(2, ',', '.') }}
                            </span>

                            {% if saleActive %}
                                <span class="text-base text-gray-500 line-through">
                                    € {{ regularPrice|number_format(2, ',', '.') }}
                                </span>
                            {% elseif compareAtPrice and compareAtPrice > displayPrice %}
                                <span class="text-sm text-gray-500">
                                    adviesprijs
                                    <span class="line-through">
                                        € {{ compareAtPrice|number_format(2, ',', '.') }}
                                    </span>
                                </span>
                            {% endif %}
                        </div>
                    </div>
                {% endif %}

                {% if availability %}
                    <div class="mt-4 text-sm">
                        {% if availability.status == 'in_stock' %}
                            <span class="font-semibold text-emerald-700">Op voorraad</span>
                            <span class="text-gray-500">– {{ availability.deliveryLabel }}</span>
                        {% elseif availability.status == 'backorder' %}
                            <span class="font-semibold text-amber-700">Op voorraad</span>
                            <span class="text-gray-500">– {{ availability.deliveryLabel }}</span>
                        {% else %}
                            <span class="font-semibold text-gray-500">Tijdelijk uitverkocht</span>
                        {% endif %}
                    </div>
                {% endif %}

                <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
                    {% if availability and availability.status == 'out_of_stock' %}
                        <button type="button"
                                disabled
                                class="inline-flex items-center justify-center rounded-full border border-gray-200 bg-gray-100 px-6 py-3 text-sm font-semibold text-gray-400">
                            Tijdelijk uitverkocht
                        </button>
                    {% else %}
                        <form
                            method="post"
                            action="{{ path('cart_add') }}"
                            class="inline-flex js-meta-add-to-cart"
                            data-meta-content-id="{{ variant.variantSku|e('html_attr') }}"
                            data-meta-value="{{ variant.displayPrice|default(variant.price)|default(0)|number_format(2, '.', '') }}"
                            data-meta-currency="EUR"
                        >
                            <input type="hidden" name="variantSku" value="{{ variant.variantSku }}">
                            <input type="hidden" name="qty" value="1">

                            <button type="submit"
                                    class="inline-flex items-center justify-center rounded-full px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:opacity-90"
                                    style="background-color: #ea7600;">
                                In winkelwagen
                            </button>
                        </form>
                    {% endif %}

                    <a href="#details"
                       class="text-sm font-semibold text-gray-600 transition hover:text-gray-900">
                        Bekijk details →
                    </a>
                </div>
            </div>

            <aside class="w-full max-w-md rounded-2xl bg-[#f4f1ea] p-6 shadow-[0_18px_45px_rgba(15,23,42,0.08)] lg:mt-8">
                <div class="text-xs font-semibold tracking-[0.18em] uppercase text-gray-500">
                    Waarom kopen bij Topbags?
                </div>

                <ul class="mt-5 space-y-4 text-sm leading-6 text-gray-700">
                    <li class="flex gap-3">
                        <span class="mt-0.5 shrink-0 text-base font-bold text-emerald-700">✓</span>
                        <span>Spaar direct Travelmiles voor extra voordeel</span>
                    </li>

                    <li class="flex gap-3">
                        <span class="mt-0.5 shrink-0 text-base font-bold text-emerald-700">✓</span>
                        <span>Eigen reparatieservice in Hengelo</span>
                    </li>

                    <li class="flex gap-3">
                        <span class="mt-0.5 shrink-0 text-base font-bold text-emerald-700">✓</span>
                        <span>Al generaties lang kofferspecialist van Twente</span>
                    </li>

                    {% if product.brand %}
                        <li class="flex gap-3">
                            <span class="mt-0.5 shrink-0 text-base font-bold text-emerald-700">✓</span>
                            <span>Officieel dealer van {{ product.brand.name }}</span>
                        </li>
                    {% endif %}
                </ul>

                <p class="mt-6 border-t border-black/10 pt-5 text-xs leading-5 text-gray-500">
                    Online bestellen of afhalen in onze winkel aan de Wemenstraat in Hengelo.
                </p>
            </aside>

        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const forms = document.querySelectorAll('.js-meta-add-to-cart');

        forms.forEach(function (form) {
            form.addEventListener('submit', function () {
                if (typeof fbq !== 'function') {
                    return;
                }

                const contentId = form.dataset.metaContentId || '';

                if (!contentId) {
                    return;
                }

                fbq('track', 'AddToCart', {
                    content_ids: [contentId],
                    content_type: 'product',
                    value: parseFloat(form.dataset.metaValue || '0'),
                    currency: form.dataset.metaCurrency || 'EUR'
                });
            });
        });
    });
</script>