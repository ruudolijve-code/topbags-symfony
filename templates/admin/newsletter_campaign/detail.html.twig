{% extends '@EasyAdmin/crud/detail.html.twig' %}

{% block main %}
    {% set campaign = entity.instance %}
    {% set stats = deliveryStatistics|default({
        total: 0,
        queued: 0,
        smtpAccepted: 0,
        likelyDelivered: 0,
        directFailed: 0,
        hardBounce: 0,
        softBounce: 0,
        technicalFailure: 0,
        review: 0,
        deliveryRate: 0
    }) %}

    <section class="mb-4">
        <div class="mb-3">
            <h2 class="h5 mb-1">
                Afleverstatistieken
            </h2>

            <p class="text-muted mb-0">
                Resultaten van deze nieuwsbrief per afzonderlijke ontvanger.
            </p>
        </div>

        {% if stats.total > 0 %}
            {# Hoofdstatistieken #}
            <div class="row g-3 mb-3">
                <div class="col-sm-6 col-xl-3">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <div class="small text-muted mb-1">
                                Ontvangers
                            </div>

                            <div class="fs-3 fw-semibold">
                                {{ stats.total }}
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-sm-6 col-xl-3">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <div class="small text-muted mb-1">
                                SMTP geaccepteerd
                            </div>

                            <div class="fs-3 fw-semibold">
                                {{ stats.smtpAccepted }}
                            </div>

                            <div class="small text-muted mt-1">
                                Door de uitgaande mailserver aangenomen
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-sm-6 col-xl-3">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <div class="small text-muted mb-1">
                                Waarschijnlijk afgeleverd
                            </div>

                            <div class="fs-3 fw-semibold">
                                {{ stats.likelyDelivered }}
                            </div>

                            <div class="small text-muted mt-1">
                                Geen latere bounce geregistreerd
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-sm-6 col-xl-3">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <div class="small text-muted mb-1">
                                Afleverpercentage
                            </div>

                            <div class="fs-3 fw-semibold">
                                {{ stats.deliveryRate|number_format(1, ',', '.') }}%
                            </div>

                            <div class="small text-muted mt-1">
                                Waarschijnlijk afgeleverd ten opzichte van ontvangers
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            {# Statusdetails #}
            <div class="row g-3 mb-4">
                <div class="col-sm-6 col-lg-4 col-xl-2">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="small text-muted mb-1">
                                In wachtrij
                            </div>

                            <div class="fs-4 fw-semibold">
                                {{ stats.queued }}
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-sm-6 col-lg-4 col-xl-2">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="small text-muted mb-1">
                                Direct mislukt
                            </div>

                            <div class="fs-4 fw-semibold">
                                {{ stats.directFailed }}
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-sm-6 col-lg-4 col-xl-2">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="small text-muted mb-1">
                                Hard bounce
                            </div>

                            <div class="fs-4 fw-semibold">
                                {{ stats.hardBounce }}
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-sm-6 col-lg-4 col-xl-2">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="small text-muted mb-1">
                                Soft bounce
                            </div>

                            <div class="fs-4 fw-semibold">
                                {{ stats.softBounce }}
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-sm-6 col-lg-4 col-xl-2">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="small text-muted mb-1">
                                Technische fout
                            </div>

                            <div class="fs-4 fw-semibold">
                                {{ stats.technicalFailure }}
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-sm-6 col-lg-4 col-xl-2">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="small text-muted mb-1">
                                Te beoordelen
                            </div>

                            <div class="fs-4 fw-semibold">
                                {{ stats.review }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            {% if stats.queued > 0 %}
                <div class="alert alert-info mb-4">
                    De verzending is nog niet volledig afgerond.
                    Er staan nog {{ stats.queued }} bericht(en) in de wachtrij.
                </div>
            {% endif %}
        {% elseif campaign.status == 'sent' %}
            {#
                Oude campagne zonder delivery-records.
                De bestaande tellingen worden getoond, maar niet als
                betrouwbare afleverstatistieken gepresenteerd.
            #}
            <div class="alert alert-warning mb-3">
                <strong>Geen afleverdetails beschikbaar.</strong>

                <div class="mt-1">
                    Deze campagne is verzonden vóór de invoering van
                    delivery-tracking. De onderstaande cijfers zijn oude
                    verzendtellingen en kunnen niet betrouwbaar aan latere
                    bounces worden gekoppeld.
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-sm-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <div class="small text-muted mb-1">
                                Ontvangers
                            </div>

                            <div class="fs-3 fw-semibold">
                                {{ campaign.recipientCount }}
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-sm-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <div class="small text-muted mb-1">
                                SMTP geaccepteerd
                            </div>

                            <div class="fs-3 fw-semibold">
                                {{ campaign.sentCount }}
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-sm-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <div class="small text-muted mb-1">
                                Direct mislukt
                            </div>

                            <div class="fs-3 fw-semibold">
                                {{ campaign.failedCount }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% elseif campaign.status == 'sending' %}
            <div class="alert alert-info mb-4">
                De nieuwsbrief wordt momenteel verwerkt. De afleverstatistieken
                worden bijgewerkt zodra de berichten uit de wachtrij worden
                verstuurd.
            </div>
        {% else %}
            <div class="alert alert-secondary mb-4">
                Voor deze conceptcampagne zijn nog geen e-mails ingepland.
                Afleverstatistieken verschijnen zodra de verzending wordt gestart.
            </div>
        {% endif %}
    </section>

    {{ parent() }}
{% endblock %}