<!doctype html>
<html lang="nl">
<head>
    <meta charset="utf-8">
    <title>Testmail versturen - {{ campaign.title }}</title>
    <style>
        body {
            margin: 0;
            padding: 32px;
            background: #f8fafc;
            color: #111827;
            font-family: Arial, sans-serif;
        }

        .page {
            max-width: 720px;
            margin: 0 auto;
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 16px;
            padding: 28px;
            box-shadow: 0 1px 4px rgba(15, 23, 42, .08);
        }

        h1 {
            margin: 0 0 8px;
            font-size: 28px;
        }

        p {
            color: #4b5563;
            line-height: 1.6;
        }

        label {
            display: block;
            margin: 24px 0 8px;
            font-weight: 700;
        }

        input {
            width: 100%;
            box-sizing: border-box;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            padding: 12px 14px;
            font-size: 16px;
        }

        .actions {
            display: flex;
            gap: 12px;
            margin-top: 22px;
        }

        button,
        a.button {
            display: inline-block;
            border: 0;
            border-radius: 8px;
            padding: 12px 16px;
            font-weight: 700;
            font-size: 14px;
            text-decoration: none;
            cursor: pointer;
        }

        button {
            background: #0B1C3D;
            color: #ffffff;
        }

        a.button {
            background: #f3f4f6;
            color: #1f2937;
        }
    </style>
</head>
<body>
    <main class="page">
        <h1>Testmail versturen</h1>

        <p>
            Nieuwsbrief: <strong>{{ campaign.title }}</strong><br>
            Onderwerp: <strong>{{ campaign.subject }}</strong>
        </p>

        <form method="post">
            <input type="hidden" name="_token" value="{{ csrf_token('newsletter_test_mail_' ~ campaign.id) }}">

            <label for="email">Test e-mailadres</label>
            <input
                type="email"
                id="email"
                name="email"
                value="ruudolijve@me.com"
                required
                autocomplete="email"
            >

            <div class="actions">
                <button type="submit">
                    Verstuur testmail
                </button>

                <a href="{{ detailUrl }}" class="button">
                    Terug
                </a>
            </div>
        </form>
    </main>
</body>
</html>