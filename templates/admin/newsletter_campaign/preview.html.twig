<!doctype html>
<html lang="nl">
<head>
    <meta charset="utf-8">
    <title>Preview nieuwsbrief - {{ campaign.title }}</title>
    <style>
        body {
            margin: 0;
            padding: 32px;
            background: #f8fafc;
            color: #111827;
            font-family: Arial, sans-serif;
        }

        .page {
            max-width: 1100px;
            margin: 0 auto;
        }

        .header {
            display: flex;
            justify-content: space-between;
            gap: 24px;
            align-items: flex-start;
            border-bottom: 1px solid #d1d5db;
            padding-bottom: 24px;
            margin-bottom: 24px;
        }

        .eyebrow {
            margin: 0 0 8px;
            color: #6b7280;
            font-size: 13px;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
        }

        h1 {
            margin: 0 0 20px;
            font-size: 36px;
            line-height: 1.15;
        }

        .meta {
            display: grid;
            gap: 8px;
            font-size: 16px;
            color: #374151;
        }

        .meta strong {
            color: #1f2937;
        }

        .button {
            display: inline-block;
            border: 1px solid #cbd5e1;
            background: #ffffff;
            color: #1f2937;
            text-decoration: none;
            border-radius: 8px;
            padding: 10px 16px;
            font-weight: 700;
            white-space: nowrap;
        }

        .preview-card {
            overflow: hidden;
            border: 1px solid #d1d5db;
            border-radius: 16px;
            background: #ffffff;
            box-shadow: 0 1px 4px rgba(15, 23, 42, .08);
        }

        .preview-card-header {
            padding: 16px 20px;
            border-bottom: 1px solid #e5e7eb;
            font-weight: 700;
            color: #374151;
            background: #ffffff;
        }

        iframe {
            width: 100%;
            height: 1100px;
            border: 0;
            display: block;
            background: #ffffff;
        }
    </style>
</head>
<body>
    <main class="page">
        <header class="header">
            <div>
                <p class="eyebrow">Preview nieuwsbrief</p>

                <h1>{{ campaign.title }}</h1>

                <div class="meta">
                    <div><strong>Onderwerp:</strong> {{ campaign.subject }}</div>

                    {% if campaign.preheader %}
                        <div><strong>Preheader:</strong> {{ campaign.preheader }}</div>
                    {% endif %}

                    <div><strong>Status:</strong> {{ campaign.status }}</div>
                </div>
            </div>

            <a href="{{ detailUrl }}" class="button">
                Terug naar detail
            </a>
        </header>

        <section class="preview-card">
            <div class="preview-card-header">
                E-mailweergave
            </div>

            <iframe src="{{ path('admin_newsletter_campaign_preview_frame', { id: campaign.id }) }}"></iframe>
        </section>
    </main>
</body>
</html>