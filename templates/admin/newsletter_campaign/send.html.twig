{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}
    Nieuwsbrief versturen
{% endblock %}

{% block main %}
    <div class="card">
        <div class="card-body">
            <h2 class="h4 mb-3">
                {{ campaign.title }}
            </h2>

            <dl class="row mb-4">
                <dt class="col-sm-3">Onderwerp</dt>
                <dd class="col-sm-9">{{ campaign.subject }}</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">Concept</dd>

                <dt class="col-sm-3">Ontvangers</dt>
                <dd class="col-sm-9">
                    <strong>{{ recipientCount }}</strong> actieve inschrijvingen
                </dd>
            </dl>

            <div class="alert alert-danger">
                <strong>Let op:</strong>
                na bevestiging wordt de nieuwsbrief definitief ingepland.
                De campagne kan daarna niet meer worden bewerkt of opnieuw
                worden gestart.
            </div>

            <div class="alert alert-info">
                De e-mails worden via de wachtrij verwerkt. Je hoeft deze
                pagina niet geopend te houden.
            </div>

            <form method="post">
                <input
                    type="hidden"
                    name="_token"
                    value="{{ csrf_token('newsletter_send_' ~ campaign.id) }}"
                >

                <div class="mb-4">
                    <label for="confirmation" class="form-label">
                        Typ <strong>{{ confirmationText }}</strong> om te bevestigen
                    </label>

                    <input
                        type="text"
                        id="confirmation"
                        name="confirmation"
                        class="form-control"
                        autocomplete="off"
                        required
                    >
                </div>

                <div class="d-flex gap-2">
                    <button
                        type="submit"
                        class="btn btn-danger"
                        onclick="return confirm('Weet je zeker dat je deze nieuwsbrief wilt versturen?');"
                    >
                        <i class="fa fa-paper-plane me-1"></i>
                        Definitief versturen
                    </button>

                    <a href="{{ detailUrl }}" class="btn btn-secondary">
                        Annuleren
                    </a>
                </div>
            </form>
        </div>
    </div>
{% endblock %}