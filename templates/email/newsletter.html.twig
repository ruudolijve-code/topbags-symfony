<!doctype html>
<html lang="nl">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ campaign.subject }}</title>

    <style>
        body {
            margin: 0;
            padding: 0;
            background: #f7f4ee;
        }

        table {
            border-collapse: collapse;
        }

        img {
            border: 0;
            outline: none;
            text-decoration: none;
            -ms-interpolation-mode: bicubic;
        }

        a {
            text-decoration: none;
        }

        .email-container {
            width: 640px;
            max-width: 640px;
        }

        .email-padding {
            padding-left: 30px;
            padding-right: 30px;
        }

        .stack-column {
            vertical-align: middle;
        }

        .mobile-only {
            display: none;
            max-height: 0;
            overflow: hidden;
            mso-hide: all;
        }

        @media only screen and (max-width: 640px) {
            .email-wrapper {
                padding: 0 !important;
            }

            .email-container {
                width: 100% !important;
                max-width: 100% !important;
                border-radius: 0 !important;
            }

            .email-padding {
                padding-left: 20px !important;
                padding-right: 20px !important;
            }

            .stack-column {
                display: block !important;
                width: 100% !important;
                max-width: 100% !important;
                padding-left: 0 !important;
                padding-right: 0 !important;
            }

            .stack-column img {
                width: 100% !important;
                max-width: 100% !important;
                height: auto !important;
            }

            .mobile-center {
                text-align: center !important;
            }

            .mobile-spacer {
                height: 18px !important;
                line-height: 18px !important;
                font-size: 18px !important;
            }

            .desktop-only {
                display: none !important;
                max-height: 0 !important;
                overflow: hidden !important;
                mso-hide: all !important;
            }

            .mobile-only {
                display: table !important;
                width: 100% !important;
                max-height: none !important;
                overflow: visible !important;
            }

            .mobile-title {
                font-size: 26px !important;
                line-height: 1.2 !important;
            }

            .trust-column {
                display: block !important;
                width: 100% !important;
                padding: 10px 0 !important;
            }
        }
    </style>
</head>

<body style="margin:0; padding:0; background:#f7f4ee; font-family:Arial, Helvetica, sans-serif; color:#1f2937;">
    {% if campaign.preheader %}
        <div style="display:none; max-height:0; overflow:hidden; opacity:0; color:transparent;">
            {{ campaign.preheader }}
        </div>
    {% endif %}

    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f7f4ee;">
        <tr>
            <td align="center" class="email-wrapper" style="padding:24px 12px;">

                <table role="presentation" width="640" cellspacing="0" cellpadding="0" class="email-container" style="width:640px; max-width:640px; background:#ffffff; border-radius:18px; overflow:hidden;">

                    {# Header logo #}
                    <tr>
                        <td style="padding:28px 24px 22px; text-align:center; background:#ffffff;">
                            <a href="{{ absolute_url(path('home')) }}" target="_blank" rel="noopener noreferrer" style="text-decoration:none;">
                                <img
                                    src="{{ absolute_url(asset('images/topbags.svg')) }}"
                                    alt="Topbags.nl"
                                    width="220"
                                    style="display:inline-block; width:220px; max-width:80%; height:auto; border:0; outline:none; text-decoration:none;"
                                >
                            </a>
                        </td>
                    </tr>

                    {# Subheader / trust line #}
                    <tr>
                        <td class="email-padding" style="padding-top:0; padding-bottom:24px; text-align:center; background:#ffffff;">
                            <p style="margin:0; font-size:14px; line-height:1.5; color:#6b7280;">
                                Wij zijn dol op koffers, tassen en accessoires, net zoals onze leden van onze Travelmiles dat ook zijn. 
                                Omdat wij jou als lid enorm waarderen krijg je van ons altijd extra voordeel! 
                                Ons staat team klaar om je te voorzien van eerlijk en deskundig advies, zodat je met de juiste koffer of tas aan je avontuur begint.
                            </p>
                        </td>
                    </tr>

                    {# Main content from admin #}
                    <tr>
                        <td class="email-padding" style="padding-top:34px; padding-bottom:24px; background:#ffffff;">
                            {{ campaign.htmlBody|raw }}
                        </td>
                    </tr>

                    {# Trust block #}
                    <tr>
                        <td class="email-padding" style="padding-top:24px; padding-bottom:24px; background:#f7f4ee;">
                            <table role="presentation" width="100%" cellspacing="0" cellpadding="0">
                                <tr>
                                    <td class="trust-column" width="33.33%" style="padding:10px; text-align:center; font-size:13px; line-height:1.5; color:#374151;">
                                        <strong style="color:#0B1C3D;">125 jaar ervaring</strong><br>
                                        Sinds 1900 in Hengelo
                                    </td>

                                    <td class="trust-column" width="33.33%" style="padding:10px; text-align:center; font-size:13px; line-height:1.5; color:#374151;">
                                        <strong style="color:#0B1C3D;">60+ merken</strong><br>
                                        Officieel dealer
                                    </td>

                                    <td class="trust-column" width="33.33%" style="padding:10px; text-align:center; font-size:13px; line-height:1.5; color:#374151;">
                                        <strong style="color:#0B1C3D;">Eigen winkel</strong><br>
                                        Deskundig advies
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    {# Brand banner #}
                    <tr>
                        <td class="email-padding" style="padding-top:22px; padding-bottom:22px; background:#0B1C3D; text-align:center;">
                            <p style="margin:0 0 8px; font-size:13px; color:#ffffff; font-weight:bold; text-transform:uppercase; letter-spacing:.06em;">
                                Officieel dealer van sterke merken
                            </p>

                            <p style="margin:0; font-size:15px; line-height:1.7; color:#ffffff;">
                                Samsonite • American Tourister • Eastpak • Guess • Valentino • Bear Design • Smaak Amsterdam • Kipling • Secrid • Tommy Hilfiger • En meer
                            </p>
                        </td>
                    </tr>

                    {# Social icons #}
                    <tr>
                        <td style="padding:26px 30px 18px; background:#ffffff; text-align:center;">
                            <p style="margin:0 0 14px; font-size:14px; color:#6b7280;">
                                Volg Topbags en Holtkamp
                            </p>

                            <a href="https://www.facebook.com/holtkamplederwaren"
                               target="_blank"
                               rel="noopener noreferrer"
                               style="display:inline-block; margin:0 6px; text-decoration:none;">
                                <img
                                    src="{{ absolute_url(asset('images/social/facebook.png')) }}"
                                    alt="Facebook"
                                    width="32"
                                    height="32"
                                    style="display:block; width:32px; height:32px; border:0;"
                                >
                            </a>

                            <a href="https://www.instagram.com/holtkamplederwaren"
                               target="_blank"
                               rel="noopener noreferrer"
                               style="display:inline-block; margin:0 6px; text-decoration:none;">
                                <img
                                    src="{{ absolute_url(asset('images/social/instagram.png')) }}"
                                    alt="Instagram"
                                    width="32"
                                    height="32"
                                    style="display:block; width:32px; height:32px; border:0;"
                                >
                            </a>

                            <a href="https://www.youtube.com/@Topbagsnl"
                               target="_blank"
                               rel="noopener noreferrer"
                               style="display:inline-block; margin:0 6px; text-decoration:none;">
                                <img
                                    src="{{ absolute_url(asset('images/social/youtube.png')) }}"
                                    alt="YouTube"
                                    width="32"
                                    height="32"
                                    style="display:block; width:32px; height:32px; border:0;"
                                >
                            </a>
                        </td>
                    </tr>

                    {# Footer #}
                    <tr>
                        <td class="email-padding" style="padding-top:24px; padding-bottom:24px; background:#f3f4f6; font-size:13px; color:#6b7280; line-height:1.5; text-align:center;">
                            <p style="margin:0 0 16px;">
                                Je ontvangt deze e-mail omdat je je hebt ingeschreven voor de nieuwsbrief van Topbags.nl / Holtkamp tassen & koffers.
                            </p>

                            <p style="margin:0 0 18px;">
                                <a href="{{ unsubscribeUrl }}" style="color:#6b7280; text-decoration:underline;">
                                    Uitschrijven voor de nieuwsbrief
                                </a>
                            </p>

                            <a href="{{ absolute_url(path('service_store')) }}" target="_blank" rel="noopener noreferrer" style="display:inline-block; text-decoration:none;">
                                <img
                                    src="{{ absolute_url(asset('images/holtkamp.svg')) }}"
                                    alt="Holtkamp tassen & koffers"
                                    width="150"
                                    style="display:block; width:150px; max-width:80%; height:auto; border:0; outline:none; text-decoration:none; margin:0 auto;"
                                >
                            </a>

                            <p style="margin:10px 0 0; font-size:12px; color:#9ca3af;">
                                Wemenstraat 5-7 · Hengelo
                            </p>
                        </td>
                    </tr>
                </table>

            </td>
        </tr>
    </table>
</body>
</html>