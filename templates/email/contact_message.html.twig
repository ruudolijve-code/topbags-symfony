{# templates/email/contact_message.html.twig #}
<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <title>Nieuw contactbericht</title>
</head>
<body style="margin:0; padding:0; background:#f7f7f7; font-family:Arial, Helvetica, sans-serif; color:#1f2937;">
    <div style="max-width:640px; margin:0 auto; padding:32px 20px;">
        <div style="background:#ffffff; border:1px solid #e5e7eb; border-radius:16px; overflow:hidden;">
            <div style="padding:24px 28px; background:#4c3228; color:#ffffff;">
                <div style="font-size:12px; letter-spacing:0.18em; text-transform:uppercase; opacity:0.9;">
                    Topbags
                </div>
                <h1 style="margin:10px 0 0; font-size:24px; line-height:1.3; font-weight:700;">
                    Nieuw contactbericht
                </h1>
            </div>

            <div style="padding:28px;">
                <p style="margin:0 0 20px; font-size:15px; line-height:1.7; color:#4b5563;">
                    Er is een nieuw bericht verstuurd via het contactformulier op de website.
                </p>

                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="border-collapse:collapse; margin-bottom:24px;">
                    <tr>
                        <td style="width:160px; padding:10px 0; font-size:14px; font-weight:700; color:#111827; border-bottom:1px solid #f3f4f6;">
                            Naam
                        </td>
                        <td style="padding:10px 0; font-size:14px; color:#374151; border-bottom:1px solid #f3f4f6;">
                            {{ data.name }}
                        </td>
                    </tr>

                    <tr>
                        <td style="width:160px; padding:10px 0; font-size:14px; font-weight:700; color:#111827; border-bottom:1px solid #f3f4f6;">
                            E-mailadres
                        </td>
                        <td style="padding:10px 0; font-size:14px; color:#374151; border-bottom:1px solid #f3f4f6;">
                            <a href="mailto:{{ data.email }}" style="color:#4c3228; text-decoration:none;">
                                {{ data.email }}
                            </a>
                        </td>
                    </tr>

                    {% if data.phone is defined and data.phone %}
                        <tr>
                            <td style="width:160px; padding:10px 0; font-size:14px; font-weight:700; color:#111827; border-bottom:1px solid #f3f4f6;">
                                Telefoon
                            </td>
                            <td style="padding:10px 0; font-size:14px; color:#374151; border-bottom:1px solid #f3f4f6;">
                                {{ data.phone }}
                            </td>
                        </tr>
                    {% endif %}

                    {% if data.subject is defined and data.subject %}
                        <tr>
                            <td style="width:160px; padding:10px 0; font-size:14px; font-weight:700; color:#111827; border-bottom:1px solid #f3f4f6;">
                                Onderwerp
                            </td>
                            <td style="padding:10px 0; font-size:14px; color:#374151; border-bottom:1px solid #f3f4f6;">
                                {{ data.subject }}
                            </td>
                        </tr>
                    {% endif %}

                    {% if data.source is defined and data.source %}
                        <tr>
                            <td style="width:160px; padding:10px 0; font-size:14px; font-weight:700; color:#111827; border-bottom:1px solid #f3f4f6;">
                                Bron
                            </td>
                            <td style="padding:10px 0; font-size:14px; color:#374151; border-bottom:1px solid #f3f4f6;">
                                {{ data.source }}
                            </td>
                        </tr>
                    {% endif %}

                    {% if data.ip is defined and data.ip %}
                        <tr>
                            <td style="width:160px; padding:10px 0; font-size:14px; font-weight:700; color:#111827; border-bottom:1px solid #f3f4f6;">
                                IP-adres
                            </td>
                            <td style="padding:10px 0; font-size:14px; color:#374151; border-bottom:1px solid #f3f4f6;">
                                {{ data.ip }}
                            </td>
                        </tr>
                    {% endif %}

                    {% if data.userAgent is defined and data.userAgent %}
                        <tr>
                            <td style="width:160px; padding:10px 0; font-size:14px; font-weight:700; color:#111827; vertical-align:top;">
                                User agent
                            </td>
                            <td style="padding:10px 0; font-size:13px; line-height:1.6; color:#6b7280;">
                                {{ data.userAgent }}
                            </td>
                        </tr>
                    {% endif %}
                </table>

                <div style="margin-top:24px;">
                    <div style="margin-bottom:10px; font-size:14px; font-weight:700; color:#111827;">
                        Bericht
                    </div>

                    <div style="border:1px solid #e5e7eb; border-radius:12px; background:#f9fafb; padding:18px; font-size:14px; line-height:1.8; color:#374151; white-space:pre-line;">
                        {{ data.message }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>