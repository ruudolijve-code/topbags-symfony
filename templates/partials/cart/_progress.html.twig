{# templates/partials/cart/_progress.html.twig #}

{% set cartCount = cartCount|default(0) %}
{% set cartSubtotal = cartSubtotal|default(0) %}
{% set freeShippingThreshold = freeShippingThreshold|default(49) %}

{% set show = (cartCount > 0) %}

<div class="{{ show ? '' : 'hidden' }} sticky top-0 z-[60] bg-white/70 backdrop-blur">
  <div class="mx-auto max-w-[1400px] px-6">
    <div class="py-2">
      <div class="flex items-center justify-between text-[11px] text-gray-500">

        {% set remaining = freeShippingThreshold - cartSubtotal %}

        {% if remaining > 0 %}
          <span>Nog € {{ remaining|number_format(2, ',', '.') }} tot gratis verzending</span>
        {% else %}
          <span>Gratis verzending actief</span>
        {% endif %}

        <a href="{{ path('cart_show') }}" class="hover:text-gray-900 transition">
          Winkelwagen ({{ cartCount }})
        </a>
      </div>

      {% set pct = (cartSubtotal / freeShippingThreshold * 100) %}
      {% if pct > 100 %}{% set pct = 100 %}{% endif %}
      {% if pct < 0 %}{% set pct = 0 %}{% endif %}

      <div class="mt-2 h-[2px] w-full bg-gray-200 rounded-full overflow-hidden">
        <div class="h-full bg-gray-900 transition-all duration-700"
             style="width: {{ pct }}%"></div>
      </div>

    </div>
  </div>
</div>