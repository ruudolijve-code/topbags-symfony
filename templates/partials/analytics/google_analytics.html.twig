{% if ga4_measurement_id is defined and ga4_measurement_id %}
    <script async src="https://www.googletagmanager.com/gtag/js?id={{ ga4_measurement_id|e('html_attr') }}"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}

        gtag('js', new Date());

        gtag('config', '{{ ga4_measurement_id|e('js') }}', {
            debug_mode: true,
            send_page_view: true
        });

        gtag('event', 'page_view', {
            debug_mode: true,
            page_location: window.location.href,
            page_title: document.title,
            page_path: window.location.pathname
        });
    </script>
{% endif %}