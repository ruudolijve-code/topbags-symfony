{% if ga4_measurement_id is defined and ga4_measurement_id %}
    <script async src="https://www.googletagmanager.com/gtag/js?id={{ ga4_measurement_id|e('html_attr') }}"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        
        // Haal de huidige status op uit de cookie (client-side)
        const getCookie = (name) => {
            const value = `; ${document.cookie}`;
            const parts = value.split(`; ${name}=`);
            if (parts.length === 2) return parts.pop().split(';').shift();
        }

        const consentStatus = getCookie('cookie_analytics') === 'granted' ? 'granted' : 'denied';

        gtag('js', new Date());
        gtag('consent', 'default', {
            'analytics_storage': consentStatus
        });
        gtag('config', '{{ ga4_measurement_id|e('js') }}');
    </script>
{% endif %}