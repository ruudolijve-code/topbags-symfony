<nav class="bg-white border-b border-gray-200">

    {# =========================
       LAAG 1 · Logo · Search · Account
       ========================= #}
    <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">

        {# Logo #}
        <a href="{{ path('home') }}" class="shrink-0 mt-4 w-50 h-auto flex items-center justify-center">
            <img
                src="{{ asset('images/topbags.svg') }}"
                alt="Topbags"
                class="w-full h-full"
            >
        </a>

        {# Search #}
        <div class="hidden lg:flex flex-1 max-w-md mx-10">
            <form action="{{ path('search') }}" method="get" role="search">
                <div class="relative">
                    <input
                        type="search"
                        name="q"
                        value="{{ app.request.query.get('q') }}"
                        placeholder="Zoek naar koffers, tassen en merken"
                        aria-label="Zoeken"
                        class="w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 pr-12 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:border-gray-400"
                    >

                    <button
                        type="submit"
                        class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-700 transition"
                        aria-label="Zoeken"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg"
                            class="w-5 h-5"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35m1.6-5.4a7 7 0 1 1-14 0 7 7 0 0 1 14 0Z" />
                        </svg>
                    </button>
                </div>
            </form>
        </div>

        {# Account / service #}
        <div class="flex items-center gap-6 text-sm font-medium text-gray-600">

            <a href="{{ path('account_login') }}"
            class="relative flex flex-col items-center justify-center text-gray-700 hover:text-amber-700 transition-colors">
                <span class="relative inline-flex items-center justify-center w-6 h-6">
                    {{ include('partials/icons/account.svg.twig') }}

                    
                </span>
                <span class="hidden sm:block text-xs mt-1">Account</span>
            </a>

            <a href="{{ path('cart_show') }}"
            class="relative flex flex-col items-center justify-center text-gray-700 hover:text-amber-700 transition-colors">
                <span class="relative inline-flex items-center justify-center w-6 h-6">
                    {{ include('partials/icons/cart.svg.twig') }}

                    {% if cartCount > 0 %}
                        <span class="absolute -top-2 -right-2 min-w-[20px] h-5 px-1 rounded-full bg-amber-600 text-white text-[11px] leading-5 text-center font-semibold">
                            {{ cartCount }}
                        </span>
                    {% endif %}
                </span>
                <span class="hidden sm:block text-xs mt-1">Winkelwagen</span>
            </a>
        </div>
    </div>