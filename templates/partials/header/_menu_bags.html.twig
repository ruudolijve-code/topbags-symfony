{# =========================
   LAAG 2 · MENU (BAGS)
   ========================= #}

{% set tassenMenuSlugs = [
    'clutches',
    'shopper',
    'a4-tassen',
    'handtassen',
    'crossbodys',
    'schoudertassen',
    'telefoontasje'
] %}

{% set mainMenuSlugs = [
    'rugtassen',
    'laptoptassen',
    'fashion-merken'
] %}

<div class="bg-gray-50 border-t border-gray-200 relative z-40">
    <div class="max-w-7xl mx-auto px-6 h-12 flex items-center justify-center">

        <ul class="flex items-center gap-10 h-full text-[14px] font-bold uppercase tracking-wider">

            {# =========================
               TASSEN DROPDOWN
               ========================= #}
            <li class="group h-full flex items-center">

                <a
                    href="{{ path('category_show', { slug: 'damestassen' }) }}"
                    class="flex items-center gap-1.5 h-full text-gray-800 transition-colors hover:text-amber-800"
                >
                    Tassen

                    <svg
                        class="w-3.5 h-3.5 text-gray-400 group-hover:text-amber-800 transition-colors"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2.5"
                            d="M19 9l-7 7-7-7"
                        />
                    </svg>
                </a>

                <div
                    class="absolute left-0 top-full w-full bg-white
                           border-b border-gray-200 shadow-xl
                           opacity-0 invisible
                           group-hover:opacity-100
                           group-hover:visible
                           transition-all duration-200 z-50"
                >
                    <div class="max-w-7xl mx-auto px-6 py-10 grid grid-cols-4 gap-8">

                        <a
                            href="{{ path('category_show', { slug: 'damestassen' }) }}"
                            class="group/item"
                        >
                            <p class="font-bold text-gray-900 group-hover/item:text-amber-800 transition-colors">
                                Alle tassen
                            </p>
                            <p class="text-xs text-gray-400 uppercase tracking-wide">
                                Bekijk complete collectie
                            </p>
                        </a>

                        {% for wantedSlug in tassenMenuSlugs %}
                            {% for category in menuBagsCategories %}
                                {% if category.slug == wantedSlug %}
                                    <a
                                        href="{{ path('category_show', { slug: category.slug }) }}"
                                        class="group/item"
                                    >
                                        <p class="font-bold text-gray-900 group-hover/item:text-amber-800 transition-colors">
                                            {{ category.menuLabel ?? category.name }}
                                        </p>
                                        <p class="text-xs text-gray-400 uppercase tracking-wide">
                                            Ontdek collectie
                                        </p>
                                    </a>
                                {% endif %}
                            {% endfor %}
                        {% endfor %}

                    </div>
                </div>
            </li>

            {# =========================
            LOSSE HOOFD ITEMS
            ========================= #}
            <li class="h-full flex items-center">
                <a
                    href="{{ path('category_show', { slug: 'rugtassen' }) }}"
                    class="flex h-full items-center text-gray-800 transition-colors hover:text-amber-800"
                >
                    Rugtassen
                </a>
            </li>

            <li class="h-full flex items-center">
                <a
                    href="{{ path('category_show', { slug: 'laptoptassen' }) }}"
                    class="flex h-full items-center text-gray-800 transition-colors hover:text-amber-800"
                >
                    Laptoptassen
                </a>
            </li>

            <li class="h-full flex items-center">
                <a
                    href="{{ path('category_show', { slug: 'fashion-merken' }) }}"
                    class="flex h-full items-center text-gray-800 transition-colors hover:text-amber-800"
                >
                    Fashion merken
                </a>
            </li>

            {# Vast sale-item in hoofdnav #}
            <li class="h-full flex items-center">
                <a
                    href="{{ path('sale_index', { context: 'bags' }) }}"
                    class="flex h-full items-center text-red-600 transition-colors hover:text-red-700"
                >
                    Sale
                </a>
            </li>

        </ul>

    </div>
</div>

</nav>