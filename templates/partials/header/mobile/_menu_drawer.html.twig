{% set initialContext = currentContext ?? context ?? 'shop' %}

<div
    x-show="mobileMenuOpen"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="-translate-x-full opacity-0"
    x-transition:enter-end="translate-x-0 opacity-100"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="translate-x-0 opacity-100"
    x-transition:leave-end="-translate-x-full opacity-0"
    class="fixed inset-0 z-[100] lg:hidden"
    style="display: none;"
>
    <div
        class="absolute inset-0 bg-black/30"
        @click="mobileMenuOpen = false"
    ></div>

    <div
        class="absolute inset-y-0 left-0 w-[88%] max-w-[420px] bg-white shadow-2xl overflow-y-auto"
        x-data="{ openCategory: null, mobileContext: '{{ initialContext }}' }"
    >
        <div class="flex items-center justify-between px-4 py-4 border-b border-gray-200">
            <a href="{{ path('home') }}">
                <img
                    src="{{ asset('images/topbags.svg') }}"
                    alt="Topbags"
                    class="h-10 w-auto"
                >
            </a>

            <button
                type="button"
                @click="mobileMenuOpen = false"
                class="inline-flex items-center justify-center w-11 h-11 rounded-md bg-gray-900 text-white"
                aria-label="Sluit menu"
            >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        {# =========================
           CONTEXT SWITCHER
           ========================= #}
        <div class="border-b border-gray-200 bg-gray-50">
            <div class="grid grid-cols-2">
                <button
                    type="button"
                    @click="mobileContext = 'shop'; openCategory = null"
                    class="px-4 py-4 text-center text-[13px] font-bold uppercase tracking-widest border-r border-gray-200 transition-colors"
                    :class="mobileContext === 'shop'
                        ? 'bg-white text-amber-600 border-b-2 border-b-amber-600'
                        : 'text-gray-500 hover:text-amber-600'"
                >
                    Koffers &amp; Reistassen
                </button>

                <button
                    type="button"
                    @click="mobileContext = 'bags'; openCategory = null"
                    class="px-4 py-4 text-center text-[13px] font-bold uppercase tracking-widest transition-colors"
                    :class="mobileContext === 'bags'
                        ? 'bg-white text-amber-600 border-b-2 border-b-amber-600'
                        : 'text-gray-500 hover:text-amber-600'"
                >
                    Damestassen
                </button>
            </div>
        </div>

        {# =========================
           SHOP CONTEXT
           ========================= #}
        <template x-if="mobileContext === 'shop'">
            <div>
                <div class="px-5 py-4 border-b border-gray-200 bg-white">
                    <a
                        href="{{ path('shop_index') }}"
                        class="block w-full rounded-lg bg-gray-900 px-5 py-4 text-center text-sm font-bold uppercase tracking-widest text-white"
                        @click="mobileMenuOpen = false"
                    >
                        Alle koffers &amp; reistassen
                    </a>
                </div>

                <nav class="border-b border-gray-200">
                    {% for category in menuShopCategories %}
                        {% set categoryKey = category.id ?? loop.index %}
                        <div class="border-b border-gray-200 last:border-b-0">
                            {% if category.children|length > 0 %}
                                <button
                                    type="button"
                                    @click="openCategory = openCategory === 'shop-{{ categoryKey }}' ? null : 'shop-{{ categoryKey }}'"
                                    class="w-full flex items-center justify-between px-5 py-5 text-left text-[26px] font-semibold text-gray-900"
                                    :aria-expanded="openCategory === 'shop-{{ categoryKey }}'"
                                >
                                    <span>{{ category.menuLabel ?? category.name }}</span>

                                    <svg
                                        class="w-5 h-5 text-gray-500 transition-transform duration-200"
                                        :class="openCategory === 'shop-{{ categoryKey }}' ? 'rotate-180' : ''"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        stroke-width="2"
                                    >
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </button>

                                <div
                                    x-show="openCategory === 'shop-{{ categoryKey }}'"
                                    x-collapse
                                    class="bg-gray-50 border-t border-gray-200"
                                >
                                    <div class="py-2">
                                        <a
                                            href="{{ path('category_show', { slug: category.slug }) }}"
                                            class="block px-5 py-3 text-sm font-semibold uppercase tracking-wide text-amber-800"
                                            @click="mobileMenuOpen = false"
                                        >
                                            Bekijk alles in {{ category.menuLabel ?? category.name }}
                                        </a>

                                        {% for child in category.children %}
                                            <a
                                                href="{{ path('category_show', { slug: child.slug }) }}"
                                                class="flex items-center justify-between px-5 py-4 text-base text-gray-800 border-t border-gray-200"
                                                @click="mobileMenuOpen = false"
                                            >
                                                <span>{{ child.menuLabel ?? child.name }}</span>
                                                <span class="text-gray-400" aria-hidden="true">→</span>
                                            </a>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% else %}
                                <a
                                    href="{{ path('category_show', { slug: category.slug }) }}"
                                    class="flex items-center justify-between px-5 py-5 text-[26px] font-semibold text-gray-900"
                                    @click="mobileMenuOpen = false"
                                >
                                    <span>{{ category.menuLabel ?? category.name }}</span>
                                    <span aria-hidden="true">→</span>
                                </a>
                            {% endif %}
                        </div>
                    {% endfor %}
                </nav>

                <div class="h-3 bg-gray-100 border-y border-gray-200"></div>

                <div class="py-2">
                    <a href="{{ path('guide_index') }}" class="block px-5 py-5 text-xl text-gray-900 border-b border-gray-200" @click="mobileMenuOpen = false">
                        Bagage-gids
                    </a>
                    <a href="{{ path('brand_index') }}" class="block px-5 py-5 text-xl text-gray-900 border-b border-gray-200" @click="mobileMenuOpen = false">
                        Merken
                    </a>
                    <a href="{{ path('airline_index') }}" class="block px-5 py-5 text-xl text-gray-900 border-b border-gray-200" @click="mobileMenuOpen = false">
                        Vliegmaatschappijen
                    </a>
                    <a href="{{ path('rental_index') }}" class="block px-5 py-5 text-xl text-gray-900 border-b border-gray-200" @click="mobileMenuOpen = false">
                        Huren
                    </a>
                    <a href="{{ path('travelmiles_index') }}" class="block px-5 py-5 text-xl text-gray-900 border-b border-gray-200" @click="mobileMenuOpen = false">
                        TravelMiles sparen
                    </a>
                    <a href="{{ path('repair_index') }}" class="block px-5 py-5 text-xl text-gray-900" @click="mobileMenuOpen = false">
                        Reparatie &amp; servicepunt
                    </a>
                </div>
            </div>
        </template>

        {# =========================
           BAGS CONTEXT
           ========================= #}
        <template x-if="mobileContext === 'bags'">
            <div>
                <div class="px-5 py-4 border-b border-gray-200 bg-white">
                    <a
                        href="{{ path('bags_index') }}"
                        class="block w-full rounded-lg bg-gray-900 px-5 py-4 text-center text-sm font-bold uppercase tracking-widest text-white"
                        @click="mobileMenuOpen = false"
                    >
                        Alle tassen
                    </a>
                </div>

                <nav class="border-b border-gray-200">
                    {% for category in menuBagsCategories %}
                        {% set categoryKey = category.id ?? (loop.index + 1000) %}
                        <div class="border-b border-gray-200 last:border-b-0">
                            {% if category.children|length > 0 %}
                                <button
                                    type="button"
                                    @click="openCategory = openCategory === 'bags-{{ categoryKey }}' ? null : 'bags-{{ categoryKey }}'"
                                    class="w-full flex items-center justify-between px-5 py-5 text-left text-[26px] font-semibold text-gray-900"
                                    :aria-expanded="openCategory === 'bags-{{ categoryKey }}'"
                                >
                                    <span>{{ category.menuLabel ?? category.name }}</span>

                                    <svg
                                        class="w-5 h-5 text-gray-500 transition-transform duration-200"
                                        :class="openCategory === 'bags-{{ categoryKey }}' ? 'rotate-180' : ''"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        stroke-width="2"
                                    >
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </button>

                                <div
                                    x-show="openCategory === 'bags-{{ categoryKey }}'"
                                    x-collapse
                                    class="bg-gray-50 border-t border-gray-200"
                                >
                                    <div class="py-2">
                                        <a
                                            href="{{ path('category_show', { slug: category.slug }) }}"
                                            class="block px-5 py-3 text-sm font-semibold uppercase tracking-wide text-amber-800"
                                            @click="mobileMenuOpen = false"
                                        >
                                            Bekijk alles in {{ category.menuLabel ?? category.name }}
                                        </a>

                                        {% for child in category.children %}
                                            <a
                                                href="{{ path('category_show', { slug: child.slug }) }}"
                                                class="flex items-center justify-between px-5 py-4 text-base text-gray-800 border-t border-gray-200"
                                                @click="mobileMenuOpen = false"
                                            >
                                                <span>{{ child.menuLabel ?? child.name }}</span>
                                                <span class="text-gray-400" aria-hidden="true">→</span>
                                            </a>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% else %}
                                <a
                                    href="{{ path('category_show', { slug: category.slug }) }}"
                                    class="flex items-center justify-between px-5 py-5 text-[26px] font-semibold text-gray-900"
                                    @click="mobileMenuOpen = false"
                                >
                                    <span>{{ category.menuLabel ?? category.name }}</span>
                                    <span aria-hidden="true">→</span>
                                </a>
                            {% endif %}
                        </div>
                    {% endfor %}
                </nav>

                <div class="h-3 bg-gray-100 border-y border-gray-200"></div>

                <div class="py-2">
                    <a href="{{ path('brand_index') }}" class="block px-5 py-5 text-xl text-gray-900 border-b border-gray-200" @click="mobileMenuOpen = false">
                        Merken
                    </a>
                    <a href="{{ path('travelmiles_index') }}" class="block px-5 py-5 text-xl text-gray-900 border-b border-gray-200" @click="mobileMenuOpen = false">
                        TravelMiles sparen
                    </a>
                    <a href="{{ path('travelmiles_index') }}" class="block px-5 py-5 text-xl text-gray-900" @click="mobileMenuOpen = false">
                        Inspiratie &amp; advies
                    </a>
                </div>
            </div>
        </template>
    </div>
</div>