<header class="lg:hidden bg-white border-b border-gray-200">
    <div class="flex items-center justify-between px-4 py-3">

        <button
            type="button"
            @click="mobileMenuOpen = true"
            class="inline-flex items-center justify-center w-11 h-11 rounded-md border border-gray-200 text-gray-900"
            aria-label="Open menu"
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
            </svg>
        </button>

        <a href="{{ path('home') }}" class="shrink-0">
            <img
                src="{{ asset('images/topbags.svg') }}"
                alt="Topbags"
                class="h-10 w-auto"
            >
        </a>

        <div class="flex items-center gap-3">
            <a href="/account/login" class="text-gray-900" aria-label="Account">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6.75a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.5 20.118a8.966 8.966 0 0 1 15 0" />
                </svg>
            </a>

            <a href="{{ path('cart_show') }}" class="relative text-gray-900" aria-label="Winkelwagen">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 3 1.5 1.5m0 0 1.07 9.626a1.5 1.5 0 0 0 1.493 1.374h9.338a1.5 1.5 0 0 0 1.493-1.374L18.75 6H6.375m-2.625-1.5h15.75M9 19.5a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm7.5 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
                </svg>

                {% if cartCount is defined and cartCount > 0 %}
                    <span class="absolute -top-2 -right-2 min-w-[18px] h-[18px] px-1 rounded-full bg-black text-white text-[10px] leading-[18px] text-center">
                        {{ cartCount }}
                    </span>
                {% endif %}
            </a>
        </div>

    </div>
</header>