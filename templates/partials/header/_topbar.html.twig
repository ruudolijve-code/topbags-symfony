                   justify-center md:justify-between
                   gap-x-6 gap-y-1
                   text-xs md:text-sm font-medium"
        >
            <li class="flex items-center gap-2">
                {% include 'partials/icons/truck.svg.twig' with { class: 'w-4 h-4' } %}
