{% extends 'base.html.twig' %}

{% block title %}
    {{ category.name }} – Topbags
{% endblock %}

{% block body %}
<div class="w-full border-b border-gray-200 bg-grey-50">
    <div class="max-w-7xl mx-auto px-6 py-8">

        <header class="mb-8">
            <h1 class="text-3xl font-bold mb-4">
                {{ category.name }}
            </h1>

            {% if category.description %}
                <div class="max-w-3xl text-lg text-gray-600">
                    {{ category.description|raw }}
                </div>
            {% endif %}
        </header>

        <div class="grid grid-cols-1 gap-8 lg:grid-cols-4">

            {# Filters #}
            <aside class="rounded-xl bg-white p-6 shadow-sm lg:col-span-1">
                <form method="get" class="space-y-6">

                    {% if 'brands' in allowedFilters %}
                        {% include 'shop/filter/_filter_brands.html.twig' %}
                    {% endif %}

                    {% if 'volume' in allowedFilters %}
                        {% include 'shop/filter/_filter_volume.html.twig' %}
                    {% endif %}

                    {% if 'color' in allowedFilters %}
                        {% include 'shop/filter/_filter_color.html.twig' %}
                    {% endif %}

                    {% if 'airlines' in allowedFilters %}
                        {% include 'shop/filter/_filter_airlines.html.twig' %}
                    {% endif %}

                    {% if 'flying_scope' in allowedFilters %}
                        {% include 'shop/filter/_filter_flying_scope.html.twig' %}
                    {% endif %}

                    {% if 'cta' in allowedFilters %}
                        {% include 'shop/filter/_filter_cta.html.twig' %}
                    {% endif %}

                </form>
            </aside>

            {# Product grid #}
            <section class="lg:col-span-3">

                <div class="mb-4 text-sm text-gray-500">
                    {{ pagination.totalItems }} modellen gevonden

                    {% if totalColors is defined and totalColors > 0 %}
                        <span class="text-gray-400">– in {{ totalColors }} kleuren</span>
                    {% endif %}

                    {% if totalAvailableVariants is defined and totalAvailableVariants > 0 %}
                        <span class="text-gray-400">– {{ totalAvailableVariants }} leverbare producten</span>
                    {% endif %}
                </div>

                {% if items is not empty %}
                    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-3">
                        {% for item in items %}
                            {% include 'shop/component/card/_card.html.twig' with {
                                context: activeContext|default('shop'),
                                product: item.product,
                                variant: item.variant,
                                master: item.master,
                                mediaPath: item.mediaPath,
                                availability: item.availability
                            } only %}
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="rounded-xl bg-white p-8 text-gray-500 shadow-sm">
                        Geen producten gevonden in deze categorie.
                    </div>
                {% endif %}

                {% if pagination.totalPages > 1 %}
                    <nav class="mt-10 flex flex-wrap items-center justify-center gap-2">
                        {% set routeName = app.request.attributes.get('_route') %}
                        {% set query = app.request.query.all %}

                        {% if pagination.hasPreviousPage %}
                            <a
                                href="{{ path(routeName, { slug: category.slug }|merge(query)|merge({ page: pagination.previousPage })) }}"
                                class="rounded-full border border-gray-300 px-4 py-2 text-sm hover:bg-gray-50"
                            >
                                Vorige
                            </a>
                        {% endif %}

                        {% for p in pagination.pages %}
                            <a
                                href="{{ path(routeName, { slug: category.slug }|merge(query)|merge({ page: p })) }}"
                                class="rounded-full border px-4 py-2 text-sm {{ p == pagination.page ? 'border-black bg-black text-white' : 'border-gray-300 hover:bg-gray-50' }}"
                            >
                                {{ p }}
                            </a>
                        {% endfor %}

                        {% if pagination.hasNextPage %}
                            <a
                                href="{{ path(routeName, { slug: category.slug }|merge(query)|merge({ page: pagination.nextPage })) }}"
                                class="rounded-full border border-gray-300 px-4 py-2 text-sm hover:bg-gray-50"
                            >
                                Volgende
                            </a>
                        {% endif %}
                    </nav>
                {% endif %}

            </section>

        </div>
    </div>
</div>
{% endblock %}