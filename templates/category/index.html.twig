{% extends 'base.html.twig' %}

{% block title %}
    {{ category.name }} – Topbags
{% endblock %}

{% block body %}
{% set currentSort = currentSort|default(app.request.query.get('sort', 'recommended')) %}
{% set routeName = app.request.attributes.get('_route') %}
{% set routeParams = app.request.attributes.get('_route_params') %}
{% set queryParams = app.request.query.all %}

{% set sortOptions = {
    recommended: 'Aanbevolen',
    newest: 'Nieuwste eerst',
    bestseller: 'Meest verkocht',
    price_desc: 'Prijs aflopend',
    price_asc: 'Prijs oplopend',
    name_asc: 'Alfabetisch A - Z',
    name_desc: 'Alfabetisch Z - A'
} %}

<div
    class="w-full border-b border-gray-200 bg-grey-50"
    x-data="{ mobileFiltersOpen: false }"
>
    <div class="max-w-7xl mx-auto px-6 py-8">

        <header class="mb-8">
            <h1 class="text-3xl font-bold mb-4">
                {{ category.menuLabel ?: category.name }}
            </h1>

            {% if category.introDescription %}
                <div class="rich-text-content max-w-3xl text-lg text-gray-600 leading-relaxed">
                    {{ category.introDescription|raw }}
                </div>
            {% elseif category.description %}
                <div class="rich-text-content max-w-3xl text-lg text-gray-600 leading-relaxed">
                    {{ category.description|raw }}
                </div>
            {% endif %}
        </header>

        {# Mobiele toolbar: filter + sorteren #}
        <div class="mb-6 lg:hidden">
            <div class="flex items-center gap-3">
                <button
                    type="button"
                    @click="mobileFiltersOpen = true"
                    class="inline-flex shrink-0 items-center gap-2 rounded-lg border border-gray-300 bg-white px-4 py-3 text-sm font-medium text-gray-900 shadow-sm"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 6h18M6 12h12M10 18h4" />
                    </svg>
                    Filter
                </button>

                <form method="get" class="min-w-0 flex-1">
                    {% for key, value in queryParams %}
                        {% if key != 'sort' and key != 'page' %}
                            {% if value is iterable %}
                                {% for subValue in value %}
                                    <input type="hidden" name="{{ key }}[]" value="{{ subValue }}">
                                {% endfor %}
                            {% else %}
                                <input type="hidden" name="{{ key }}" value="{{ value }}">
                            {% endif %}
                        {% endif %}
                    {% endfor %}

                    <label for="sort-mobile" class="sr-only">
                        Sorteren
                    </label>

                    <select
                        id="sort-mobile"
                        name="sort"
                        onchange="this.form.submit()"
                        class="w-full rounded-lg border border-gray-300 bg-white px-3 py-3 text-sm font-medium text-gray-900 shadow-sm"
                    >
                        {% for value, label in sortOptions %}
                            <option value="{{ value }}" {{ currentSort == value ? 'selected' : '' }}>
                                {{ label }}
                            </option>
                        {% endfor %}
                    </select>
                </form>
            </div>

            <div class="mt-3 text-sm text-gray-500">
                {{ pagination.totalItems }} modellen gevonden

                {% if totalColors is defined and totalColors > 0 %}
                    <span class="text-gray-400">– in {{ totalColors }} kleuren</span>
                {% endif %}

                {% if totalAvailableVariants is defined and totalAvailableVariants > 0 %}
                    <span class="text-gray-400">– {{ totalAvailableVariants }} leverbare producten</span>
                {% endif %}
            </div>
        </div>

        <div class="grid grid-cols-1 gap-8 lg:grid-cols-4">

            {# Desktop filters #}
            <aside class="hidden lg:block rounded-xl bg-white p-6 shadow-sm lg:col-span-1">
                <form method="get" class="space-y-6">
                    {% if currentSort != 'recommended' %}
                        <input type="hidden" name="sort" value="{{ currentSort }}">
                    {% endif %}

                    {% if 'brands' in allowedFilters %}
                        {% include 'shop/filter/_filter_brands.html.twig' %}
                    {% endif %}

                    {% if 'volume' in allowedFilters %}
                        {% include 'shop/filter/_filter_volume.html.twig' %}
                    {% endif %}

                    {% if 'color' in allowedFilters %}
                        {% include 'shop/filter/_filter_color.html.twig' %}
                    {% endif %}

                    {% if 'airlines' in allowedFilters %}
                        {% include 'shop/filter/_filter_airlines.html.twig' %}
                    {% endif %}

                    {% if 'flying_scope' in allowedFilters %}
                        {% include 'shop/filter/_filter_flying_scope.html.twig' %}
                    {% endif %}

                    {% if 'cta' in allowedFilters %}
                        {% include 'shop/filter/_filter_cta.html.twig' %}
                    {% endif %}
                </form>
            </aside>

            {# Product grid #}
            <section class="lg:col-span-3">

                {# Desktop toolbar: telling + sorteren #}
                <div class="hidden lg:flex mb-4 items-center justify-between gap-4">
                    <div class="text-sm text-gray-500">
                        {{ pagination.totalItems }} modellen gevonden

                        {% if totalColors is defined and totalColors > 0 %}
                            <span class="text-gray-400">– in {{ totalColors }} kleuren</span>
                        {% endif %}

                        {% if totalVisibleVariants is defined and totalVisibleVariants > 0 %}
                            <span class="text-gray-400">– {{ totalVisibleVariants }} zichtbare producten</span>
                        {% endif %}
                    </div>

                    <form method="get" class="flex items-center gap-2">
                        {% for key, value in queryParams %}
                            {% if key != 'sort' and key != 'page' %}
                                {% if value is iterable %}
                                    {% for subValue in value %}
                                        <input type="hidden" name="{{ key }}[]" value="{{ subValue }}">
                                    {% endfor %}
                                {% else %}
                                    <input type="hidden" name="{{ key }}" value="{{ value }}">
                                {% endif %}
                            {% endif %}
                        {% endfor %}

                        <label for="sort-desktop" class="text-sm text-gray-500">
                            Sorteer op
                        </label>

                        <select
                            id="sort-desktop"
                            name="sort"
                            onchange="this.form.submit()"
                            class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-900 shadow-sm"
                        >
                            {% for value, label in sortOptions %}
                                <option value="{{ value }}" {{ currentSort == value ? 'selected' : '' }}>
                                    {{ label }}
                                </option>
                            {% endfor %}
                        </select>
                    </form>
                </div>

                {% if items is not empty %}
                    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-3">
                        {% for item in items %}
                            {% include 'shop/component/card/_card.html.twig' with {
                                context: activeContext|default('shop'),
                                product: item.product,
                                variant: item.variant,
                                master: item.master,
                                mediaPath: item.mediaPath,
                                availability: item.availability
                            } only %}
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="rounded-xl bg-white p-8 text-gray-500 shadow-sm">
                        Geen producten gevonden in deze categorie.
                    </div>
                {% endif %}

                {% if pagination.totalPages > 1 %}
                    <nav class="mt-10 flex flex-wrap items-center justify-center gap-2">
                        {% set query = app.request.query.all %}

                        {% if pagination.hasPreviousPage %}
                            <a
                                href="{{ path(routeName, routeParams|merge(query)|merge({ page: pagination.previousPage })) }}"
                                class="rounded-full border border-gray-300 px-4 py-2 text-sm hover:bg-gray-50"
                            >
                                Vorige
                            </a>
                        {% endif %}

                        {% for p in pagination.pages %}
                            <a
                                href="{{ path(routeName, routeParams|merge(query)|merge({ page: p })) }}"
                                class="rounded-full border px-4 py-2 text-sm {{ p == pagination.page ? 'border-black bg-black text-white' : 'border-gray-300 hover:bg-gray-50' }}"
                            >
                                {{ p }}
                            </a>
                        {% endfor %}

                        {% if pagination.hasNextPage %}
                            <a
                                href="{{ path(routeName, routeParams|merge(query)|merge({ page: pagination.nextPage })) }}"
                                class="rounded-full border border-gray-300 px-4 py-2 text-sm hover:bg-gray-50"
                            >
                                Volgende
                            </a>
                        {% endif %}
                    </nav>
                {% endif %}
            </section>
        </div>

        {% if category.seoDescription %}
            <section class="mt-14 border-t border-gray-200 pt-10">
                <div class="rich-text-content max-w-4xl text-lg text-gray-700 leading-relaxed">
                    {{ category.seoDescription|raw }}
                </div>
            </section>
        {% endif %}
    </div>

    {# Mobiele filter overlay #}
    <template x-teleport="body">
        <div
            x-show="mobileFiltersOpen"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-200"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            class="fixed inset-0 lg:hidden"
            style="display: none; z-index: 9998;"
        >
            <div
                class="fixed inset-0 bg-black/40"
                style="z-index: 9998;"
                @click="mobileFiltersOpen = false"
            ></div>

            <div
                x-show="mobileFiltersOpen"
                x-transition:enter="transition ease-out duration-300"
                x-transition:enter-start="translate-y-full"
                x-transition:enter-end="translate-y-0"
                x-transition:leave="transition ease-in duration-200"
                x-transition:leave-start="translate-y-0"
                x-transition:leave-end="translate-y-full"
                class="fixed inset-0 flex flex-col bg-white shadow-2xl"
                style="display: none; z-index: 9999;"
            >
                <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200 shrink-0 bg-white">
                    <h2 class="text-lg font-semibold text-gray-900">
                        Filters
                    </h2>

                    <button
                        type="button"
                        @click="mobileFiltersOpen = false"
                        class="inline-flex items-center justify-center h-10 w-10 rounded-md border border-gray-300 bg-white text-gray-700"
                        aria-label="Sluit filters"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>

                <form method="get" class="flex-1 overflow-y-auto px-5 py-5 space-y-6 bg-white">
                    {% if currentSort != 'recommended' %}
                        <input type="hidden" name="sort" value="{{ currentSort }}">
                    {% endif %}

                    {% if 'brands' in allowedFilters %}
                        {% include 'shop/filter/_filter_brands.html.twig' %}
                    {% endif %}

                    {% if 'volume' in allowedFilters %}
                        {% include 'shop/filter/_filter_volume.html.twig' %}
                    {% endif %}

                    {% if 'color' in allowedFilters %}
                        {% include 'shop/filter/_filter_color.html.twig' %}
                    {% endif %}

                    {% if 'airlines' in allowedFilters %}
                        {% include 'shop/filter/_filter_airlines.html.twig' %}
                    {% endif %}

                    {% if 'flying_scope' in allowedFilters %}
                        {% include 'shop/filter/_filter_flying_scope.html.twig' %}
                    {% endif %}

                    {% if 'cta' in allowedFilters %}
                        {% include 'shop/filter/_filter_cta.html.twig' %}
                    {% endif %}

                    <div class="sticky bottom-0 bg-white pt-4 pb-2 border-t border-gray-200 flex gap-3">
                        <a
                            href="{{ path(routeName, routeParams) }}"
                            class="flex-1 inline-flex items-center justify-center rounded-lg border border-gray-300 px-4 py-3 text-sm font-medium text-gray-700"
                        >
                            Wis filters
                        </a>

                        <button
                            type="submit"
                            class="flex-1 inline-flex items-center justify-center rounded-lg bg-gray-900 px-4 py-3 text-sm font-semibold text-white"
                        >
                            Toon resultaten
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </template>
</div>
{% endblock %}