                item_name: '{{ item.name|e('js') }}',
                item_brand: '{{ item.brand|default('')|e('js') }}',
                item_variant: '{{ item.color|default('')|e('js') }}',
                price: {{ item.price|number_format(2, '.', '') }},
                quantity: {{ item.qty }}
            }{% if not loop.last %},{% endif %}
            {% endfor %}
        ]
    });
</script>
