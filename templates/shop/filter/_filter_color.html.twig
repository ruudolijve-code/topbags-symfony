{# ========= Kleur ========= #}
{% if colors is defined and colors is not empty %}
    <div>
        <h2 class="font-semibold mb-3">Kleur</h2>

        <div class="flex flex-wrap gap-3">
            {% for color in colors %}
                {% set isActive = color.slug in activeColors %}

                <label
                    class="relative inline-flex cursor-pointer items-center justify-center group"
                    title="{{ color.name }}"
                >
                    <input
                        type="checkbox"
                        name="color[]"
                        value="{{ color.slug }}"
                        {% if isActive %}checked{% endif %}
                        class="sr-only peer"
                    >

                    {# kleurbol #}
                    <span
                        class="
                            block h-7 w-7 rounded-full border border-gray-300 shadow-sm
                            transition-all duration-200

                            group-hover:ring-1 group-hover:ring-gray-400 group-hover:ring-offset-2

                            peer-checked:ring-2
                            peer-checked:ring-black
                            peer-checked:ring-offset-2
                            peer-checked:border-black
                        "
                        style="background-color: {{ color.hex ?: '#d1d5db' }};"
                    ></span>

                    {# subtiele checkmark bij actief #}
                    <span
                        class="
                            absolute inset-0 flex items-center justify-center
                            text-xs font-bold text-white
                            opacity-0 transition-opacity
                            pointer-events-none

                            peer-checked:opacity-100
                        "
                    >
                        ✓
                    </span>
                </label>
            {% endfor %}
        </div>
    </div>
{% endif %}