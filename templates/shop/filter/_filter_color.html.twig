{# ========= Kleur ========= #}
{% if colors is defined and colors is not empty %}
    <div>
        <h2 class="font-semibold mb-3">Kleur</h2>

        <div class="flex flex-wrap gap-2">
            {% for color in colors %}
                {% set isActive = color.slug in activeColors|default([]) %}

                <label
                    class="relative inline-flex h-9 w-9 cursor-pointer items-center justify-center rounded-full group"
                    title="{{ color.name }}"
                >
                    <input
                        type="checkbox"
                        name="color[]"
                        value="{{ color.slug }}"
                        {% if isActive %}checked="checked"{% endif %}
                        class="peer sr-only"
                        onchange="this.form.submit()"
                    >

                    {# blijvende buitenring bij selectie + hover-ring #}
                    <span
                        class="
                            absolute inset-0 rounded-full transition-all duration-150

                            group-hover:ring-2
                            group-hover:ring-gray-400
                            group-hover:ring-offset-2

                            peer-checked:ring-2
                            peer-checked:ring-black
                            peer-checked:ring-offset-2

                            {% if isActive %}
                                ring-2 ring-black ring-offset-2
                            {% endif %}
                        "
                    ></span>

                    {# kleurbol #}
                    <span
                        class="
                            relative block h-7 w-7 rounded-full border border-gray-300 shadow-sm
                        "
                        style="background-color: {{ color.hex ?: '#d1d5db' }};"
                    ></span>

                    {# checkmark alleen wanneer actief / geselecteerd #}
                    <span
                        class="
                            absolute inset-0 flex items-center justify-center
                            text-xs font-bold text-white drop-shadow
                            opacity-0 pointer-events-none transition-opacity

                            peer-checked:opacity-100

                            {% if isActive %}
                                opacity-100
                            {% endif %}
                        "
                    >
                        ✓
                    </span>
                </label>
            {% endfor %}
        </div>
    </div>
{% endif %}