{# ========= Airline ========= #}
{% if airlines is defined and airlines is not empty %}
    <div x-data="{ airlineInfoOpen: false }">

        <div class="mb-3">
            <div class="flex items-center gap-2">
                <h2 class="font-semibold leading-tight">
                    Geschikt voor vliegen met
                </h2>

                <div class="relative inline-flex">
                    <button
                        type="button"
                        class="inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full text-gray-400 hover:text-gray-700 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:ring-offset-2"
                        @mouseenter="airlineInfoOpen = true"
                        @mouseleave="airlineInfoOpen = false"
                        @focus="airlineInfoOpen = true"
                        @blur="airlineInfoOpen = false"
                        @click="airlineInfoOpen = !airlineInfoOpen"
                        aria-label="Uitleg over airline filter"
                    >
                        {% include 'partials/icons/information.svg.twig' %}
                    </button>

                    <div
                        x-show="airlineInfoOpen"
                        x-transition
                        @mouseenter="airlineInfoOpen = true"
                        @mouseleave="airlineInfoOpen = false"
                        class="absolute left-0 top-full z-50 mt-2 w-72 max-w-[calc(100vw-2rem)] rounded-xl border border-gray-200 bg-white p-4 text-sm leading-6 text-gray-700 shadow-xl"
                        style="display: none;"
                    >
                        <p class="font-semibold text-gray-900">
                            Hoe werkt dit filter?
                        </p>

                        <p class="mt-2">
                            Selecteer eerst je luchtvaartmaatschappij. Kies daarna of je zoekt naar
                            <strong>personal item</strong>, <strong>handbagage</strong> of <strong>ruimbagage</strong>.
                            We tonen dan reisbagage die past binnen de afmetingen van deze airline.
                        </p>

                        <p class="mt-3">
                            Wil je ook weten hoeveel stuks bagage je mee mag nemen of welk volume past bij je reisduur?
                            Gebruik dan de
                            <a
                                href="{{ path('guide_index') }}"
                                class="font-semibold text-amber-700 hover:text-amber-800"
                            >
                                Topbags Bagagegids
                            </a>.
                        </p>
                    </div>
                </div>
            </div>

            <p class="mt-1 text-xs leading-5 text-gray-500">
                Kies je airline en daarna het type bagage.
            </p>
        </div>

        <div class="space-y-2">
            {% for airline in airlines %}
                <label class="flex items-center gap-2 text-sm">
                    <input
                        type="checkbox"
                        name="airline[]"
                        value="{{ airline.slug }}"
                        {% if airline.slug in activeAirlines %}checked{% endif %}
                        class="rounded border-gray-300 text-amber-600 focus:ring-amber-500"
                    >
                    <span>{{ airline.name }}</span>
                </label>
            {% endfor %}
        </div>
    </div>
{% endif %}