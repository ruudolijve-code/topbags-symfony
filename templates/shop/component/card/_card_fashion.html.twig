{# templates/shop/component/card/_card_fashion.html.twig #}

{% if product is defined and variant is defined and product and variant %}

  {% set productUrl = path('product_show', {
    slug: product.slug,
    colorSlug: variant.supplierColorSlug ?: 'default',
    variantSku: variant.variantSku
  }) %}

  {# Houd Damestassen-context vast op de productpagina #}
  {% if currentContext is defined and currentContext == 'bags' %}
    {% set productUrl = productUrl ~ '?context=bags' %}
  {% endif %}

  {# Prijslogica: gebruik altijd de daadwerkelijk getoonde variant #}
  {% set priceVariant = variant %}

  {% set displayPrice = priceVariant.displayPrice %}
  {% set regularPrice = priceVariant.price %}
  {% set compareAtPrice = priceVariant.compareAtPrice %}
  {% set saleActive = priceVariant.saleActive %}
  {% set saleBadge = priceVariant.discountBadge %}

  <article class="break-inside-avoid group">

    <a href="{{ productUrl }}" class="block">

      {# ===============================
        Editorial image
      =============================== #}
      <div class="overflow-hidden rounded-2xl bg-white border border-gray-100">

        <div class="relative aspect-[3/4]">

          {# ===============================
            Sale badge linksboven
          =============================== #}
          {% if saleActive and saleBadge %}
            <span class="absolute top-3 left-3 z-50 rounded-full bg-red-50 px-2.5 py-1 text-[11px] font-semibold text-red-600 shadow-sm">
              {{ saleBadge }}
            </span>
          {% endif %}

          {# ===============================
            Leather badge rechtsboven
          =============================== #}
          {% set materialName = product.material is defined and product.material ? product.material.name|lower|trim : '' %}

          {# Normaliseer accenten, zodat "Suède" ook als "suede" wordt herkend #}
          {% set materialKey = materialName
            |replace({
              'è': 'e',
              'é': 'e',
              'ë': 'e',
              'ê': 'e',
              'á': 'a',
              'à': 'a',
              'ä': 'a',
              'â': 'a'
            })
          %}

          {% set isLeather =
            materialKey == 'leer'
            or materialKey == 'leather'
            or materialKey == 'suede'
            or 'leer' in materialKey
            or 'leather' in materialKey
            or 'suede' in materialKey
          %}

          {% if isLeather %}
            <span class="absolute top-3 right-3 z-50 flex h-12 w-12 items-center justify-center rounded-full bg-white/95 shadow-sm">
              <span class="block h-7 w-7 text-stone-700">
                {% include 'partials/icons/leather.svg.twig' %}
              </span>
            </span>
          {% endif %}

          {# ===============================
            Product image
          =============================== #}
          {% if mediaPath is defined and mediaPath %}
            <img
              src="{{ asset(mediaPath) }}"
              alt="{{ product.name }}"
              loading="lazy"
              class="absolute inset-0 h-full w-full object-contain transition-transform duration-500 group-hover:scale-105"
            >
          {% else %}
            <div class="flex h-full items-center justify-center text-xs text-gray-400">
              Geen afbeelding
            </div>
          {% endif %}

        </div>

      </div>

      {# ===============================
        Minimal text block
      =============================== #}
      <div class="mt-4 text-center">

        {% if product.brand %}
          <div class="text-xs uppercase tracking-wide text-gray-500">
            {{ product.brand.name }}
          </div>
        {% endif %}

        <h3 class="mt-1 text-sm font-medium tracking-wide text-gray-900 line-clamp-2">
          {{ product.name }}
        </h3>

        {# ===============================
          Price
        =============================== #}
        {% if displayPrice %}
          <div class="mt-1 flex items-baseline justify-center gap-2 text-xs tracking-wide">

            <span class="{{ saleActive ? 'font-semibold text-red-600' : 'text-gray-600' }}">
              € {{ displayPrice|number_format(2, ',', '.') }}
            </span>

            {% if saleActive and regularPrice and regularPrice > displayPrice %}
              <span class="text-gray-400 line-through">
                € {{ regularPrice|number_format(2, ',', '.') }}
              </span>
            {% elseif compareAtPrice and compareAtPrice > displayPrice %}
              <span class="text-gray-400 line-through">
                € {{ compareAtPrice|number_format(2, ',', '.') }}
              </span>
            {% endif %}

          </div>
        {% endif %}

        {# ===============================
          Color variants indicator
        =============================== #}
        {% set colorVariants = product.variants|filter(v => v.isActive and v.color and v.supplierColorSlug) %}

        {% if colorVariants|length > 1 %}
          <div class="mt-4 flex items-center justify-center gap-2">

            {% for v in colorVariants|slice(0, 5) %}
              <span
                class="w-4 h-4 rounded-full border border-gray-300 {{ v.variantSku == variant.variantSku ? 'ring-1 ring-black ring-offset-1' : '' }}"
                style="background-color: {{ v.color.hex }}"
                title="{{ v.supplierColorName ?: v.color.name }}"
              ></span>
            {% endfor %}

            {% if colorVariants|length > 5 %}
              <span class="ml-1 text-xs text-gray-500">
                +{{ colorVariants|length - 5 }}
              </span>
            {% endif %}

          </div>
        {% endif %}

      </div>

    </a>

  </article>

{% endif %}

  </article>

