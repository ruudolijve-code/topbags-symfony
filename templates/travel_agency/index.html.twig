{% extends 'base.html.twig' %}

{% block title %}
    Bagagegids voor reisbureaus in Twente – Topbags
{% endblock %}

{% block body %}
<div class="bg-[#f7f4ee]">
    <section class="mx-auto max-w-7xl px-6 py-14 lg:py-20">
        <div class="max-w-3xl">
            <div class="text-sm font-semibold uppercase tracking-[0.18em] text-amber-700">
                Topbags Bagagegids
            </div>

            <h1 class="mt-4 text-4xl font-semibold tracking-tight text-gray-900 lg:text-5xl">
                Reis geboekt in Twente? Check welke bagage je nodig hebt
            </h1>

            <p class="mt-5 text-lg leading-8 text-gray-700">
                Heb je een reis geboekt of ben je je aan het oriënteren bij een reisbureau in Twente?
                Met de Topbags Bagagegids vind je snel welke koffer, handbagage of reistas past bij je reis.
            </p>

            <div class="mt-8 flex flex-wrap gap-3">
                <a href="{{ path('shop_all') }}"
                   class="inline-flex rounded-full bg-gray-900 px-5 py-3 text-sm font-semibold text-white hover:bg-gray-800">
                    Bekijk reisbagage
                </a>

                <a href="#reisbureaus"
                   class="inline-flex rounded-full border border-gray-300 bg-white px-5 py-3 text-sm font-semibold text-gray-900 hover:bg-gray-50">
                    Bekijk reisbureaus
                </a>
            </div>
        </div>
    </section>
</div>

<section id="reisbureaus" class="mx-auto max-w-7xl px-6 py-12">
    <h2 class="text-2xl font-semibold text-gray-900">
        Bagageadvies per reisbureau
    </h2>

    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {% for page in pages %}
            <a href="{{ path('travel_agency_show', { slug: page.slug }) }}"
               class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm transition hover:shadow-md">
                <div class="text-xs uppercase tracking-wide text-gray-500">
                    {{ page.city }}
                </div>

                <h3 class="mt-2 text-lg font-semibold text-gray-900">
                    {{ page.name }}
                </h3>

                <p class="mt-2 text-sm leading-6 text-gray-600">
                    Check welke koffer, handbagage of reistas past bij je reis.
                </p>
            </a>
        {% else %}
            <div class="rounded-xl bg-white p-6 text-gray-500 shadow-sm">
                Er zijn nog geen reisbureaupagina’s toegevoegd.
            </div>
        {% endfor %}
    </div>
</section>
{% endblock %}