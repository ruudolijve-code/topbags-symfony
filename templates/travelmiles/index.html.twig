{% extends 'base.html.twig' %}

{% block title %}Travelmiles – Spaar voor je volgende reis | Topbags{% endblock %}

{% block body %}
<div class="bg-amber-50">

    <!-- Hero -->
    <section class="max-w-6xl mx-auto px-6 py-20">
        <div class="max-w-3xl">
            <span class="inline-block mb-4 rounded-full bg-amber-100 px-4 py-1 text-sm font-semibold text-amber-700">
                Loyaliteitsprogramma
            </span>

            <h1 class="text-4xl font-bold text-gray-900 mb-4">
                Travelmiles
            </h1>

            <p class="text-xl text-gray-700 mb-6">
                Spaar stempels. Beleef je volgende reis al vóór vertrek.
            </p>

            <p class="text-gray-600 mb-8">
                Sommige reizen beginnen niet op het vliegveld.
                Ze beginnen bij het uitpakken van een nieuwe koffer,
                het sluiten van een rits, of het gevoel:
                <em>ik ben er bijna</em>.
            </p>

            <p class="text-gray-600 mb-8">
                Met <strong>Travelmiles</strong> van Topbags spaar je niet alleen voordeel,
                maar werk je stap voor stap toe naar je volgende reis — net zoals bij AirMiles,
                maar dan voor alles wat je meeneemt.
            </p>

            <div class="flex flex-wrap gap-4">
                <a href="#hoe-werkt-het"
                   class="rounded-xl bg-amber-600 px-6 py-3 text-white font-semibold hover:bg-amber-700 transition">
                    Zo werkt Travelmiles
                </a>
                <a href="/account"
                   class="rounded-xl bg-white px-6 py-3 text-amber-700 font-semibold border border-amber-200 hover:bg-amber-100 transition">
                    Mijn Travelmiles
                </a>
            </div>
        </div>
    </section>

    <!-- AirMiles gevoel -->
    <section class="bg-white">
        <div class="max-w-6xl mx-auto px-6 py-16 grid md:grid-cols-2 gap-12 items-center">
            <div>
                <h2 class="text-2xl font-bold mb-4">
                    Zoals AirMiles, maar dan voor jouw reisuitrusting
                </h2>

                <p class="text-gray-600 mb-4">
                    Wie TravelMiles spaart, spaart niet voor punten.
                    Je spaart voor een weekend weg.
                    Voor een upgrade.
                    Voor dat ene moment waarop je zegt: <em>nu is het zover</em>.
                </p>

                <p class="text-gray-600">
                    Travelmiles werkt precies zo.
                    Elke aankoop is een stap onderweg.
                    En bij elke stap ontvang je een <strong>stempel</strong>
                    in jouw Travelmiles-kaart.
                </p>
            </div>

            <div class="bg-amber-100 rounded-2xl p-8">
                <ul class="list-disc list-outside pl-6 space-y-3 text-gray-700 marker:text-amber-600">
                    <li>Eerste stempel bij besteding vanaf € 25</li>
                    <li>Elke stempel is € 1,25 waard</li>
                    <li>Automatisch sparen, zonder gedoe</li>
                    <li>Online én in onze winkel geldig</li>
                </ul>
            </div>
        </div>
    </section>

    <!-- Het paspoort -->
    <section id="hoe-werkt-het" class="bg-amber-100">
        <div class="max-w-6xl mx-auto px-6 py-16">
            <h2 class="text-2xl font-bold mb-6">
                Travelmiles, laat de vakantiepret al beginnen
            </h2>

            <p class="max-w-3xl text-gray-600 mb-6">
                Zie je aankopen als reizen.
                Soms klein, soms groot — maar allemaal onderdeel van jouw reisverhaal.
                Bij elke ‘reis’ ontvang je een stempel.
                Geen punten die je moet omrekenen, maar iets tastbaars dat direct waarde heeft.
            </p>

            <p class="max-w-3xl text-gray-600">
                Net als bij AirMiles bouw je iets op.
                Niet in één keer, maar stap voor stap.
                Tot je besluit: <em>nu ga ik ze gebruiken</em>.
            </p>
        </div>
    </section>

    <!-- Beloningen -->
    <section class="bg-white">
        <div class="max-w-6xl mx-auto px-6 py-16">
            <h2 class="text-2xl font-bold mb-8">
                Jouw bestemming: beloningen
            </h2>

            <div class="grid md:grid-cols-3 gap-8">
                <div class="bg-amber-50 rounded-xl p-6 border border-amber-200">
                    <h3 class="font-semibold mb-2">Korting</h3>
                    <p class="text-gray-600">
                        Gebruik je Travelmiles voor korting
                        op je volgende aankoop.
                    </p>
                </div>

                <div class="bg-amber-50 rounded-xl p-6 border border-amber-200">
                    <h3 class="font-semibold mb-2">Gratis producten</h3>
                    <p class="text-gray-600">
                        Wissel stempels in voor accessoires
                        of geselecteerde producten.
                    </p>
                </div>

                <div class="bg-amber-50 rounded-xl p-6 border border-amber-200">
                    <h3 class="font-semibold mb-2">Extra voordelen</h3>
                    <p class="text-gray-600">
                        Speciale acties en momenten
                        waarop je extra Travelmiles verdient.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Extra stempels -->
    <section class="bg-amber-50">
        <div class="max-w-6xl mx-auto px-6 py-16 grid md:grid-cols-2 gap-12 items-center">
            <div>
                <h2 class="text-2xl font-bold mb-4">
                    Extra stempels verdien je onderweg
                </h2>

                <p class="text-gray-600 mb-4">
                    Net als bij AirMiles loont het om actief te zijn.
                    Kleine stappen maken samen het verschil.
                </p>

                <ul class="list-disc list-outside pl-6 space-y-2 text-gray-600 marker:text-amber-600">
                    <li>Maak je profiel compleet</li>
                    <li>Deel je reisvoorkeuren</li>
                    <li>Doe mee aan acties of events</li>
                </ul>
            </div>

            <div class="bg-white rounded-2xl p-8 shadow-sm">
                <p class="text-gray-700">
                    Al je Travelmiles zie je overzichtelijk terug in je account.
                    Je weet altijd waar je staat — en hoe dichtbij je volgende
                    beloning is.
                </p>
            </div>
        </div>
    </section>

    <!-- Waarom -->
    <section class="bg-amber-600 text-white">
        <div class="max-w-6xl mx-auto px-6 py-16">
            <h2 class="text-2xl font-bold mb-6">
                Waarom Travelmiles
            </h2>

            <ul class="grid md:grid-cols-2 gap-4">
                <li>✓ Spaar voor iets groters dan korting</li>
                <li>✓ Elke aankoop voelt als een reisstap</li>
                <li>✓ Geen punten, maar tastbare stempels</li>
                <li>✓ Online én in de winkel geldig</li>
                <li>✓ Altijd inzicht in je voortgang</li>
                <li>✓ Helder, eerlijk en typisch Topbags</li>
            </ul>
        </div>
    </section>

</div>
{% endblock %}