{% extends 'base.html.twig' %}

{% block title %}Sale | Topbags{% endblock %}

{% block body %}
<div class="max-w-[1400px] mx-auto px-6 py-12 lg:py-16">

    <div class="max-w-3xl">
        <div class="inline-flex items-center rounded-full bg-red-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-red-600">
            Sale
        </div>

        <h1 class="mt-4 text-3xl font-semibold tracking-tight text-gray-900 lg:text-4xl">
            Afgeprijsde koffers, reistassen en accessoires
        </h1>

        <p class="mt-4 text-base leading-relaxed text-gray-600">
            Ontdek onze sale met geselecteerde koffers, reistassen en reisaccessoires.
            Op deze pagina vind je alleen producten met een actieve korting.
        </p>
    </div>

    {% if items is empty %}
        <div class="mt-12 rounded-2xl border border-gray-200 bg-white px-8 py-12">
            <div class="text-lg font-medium text-gray-900">
                Er zijn op dit moment geen sale-artikelen beschikbaar.
            </div>

            <p class="mt-2 text-sm text-gray-500">
                Bekijk intussen onze volledige collectie.
            </p>

            <a href="{{ path('shop_index') }}"
               class="mt-6 inline-flex items-center rounded-full bg-black px-6 py-3 text-sm font-semibold text-white transition hover:bg-gray-900">
                Bekijk de collectie
            </a>
        </div>
    {% else %}
        <div class="mt-10 text-sm text-gray-500">
            {{ pagination.totalItems }} sale-artikelen gevonden
        </div>

        <div class="mt-6 grid grid-cols-1 gap-8 sm:grid-cols-2 md:grid-cols-3 xl:grid-cols-3 2xl:grid-cols-4">
            {% for item in items %}
                {% include 'shop/component/card/_card_functional.html.twig' with {
                    product: item.product,
                    variant: item.variant,
                    master: item.master,
                    mediaPath: item.mediaPath,
                    availability: item.availability
                } only %}
            {% endfor %}
        </div>

        {% if pagination.totalPages > 1 %}
            <nav class="mt-12 flex flex-wrap items-center justify-center gap-2">
                {% set routeName = app.request.attributes.get('_route') %}
                {% set query = app.request.query.all %}

                {% if pagination.hasPreviousPage %}
                    <a
                        href="{{ path(routeName, query|merge({ page: pagination.previousPage })) }}"
                        class="rounded-full border border-gray-300 px-4 py-2 text-sm hover:bg-gray-50"
                    >
                        Vorige
                    </a>
                {% endif %}

                {% for p in pagination.pages %}
                    <a
                        href="{{ path(routeName, query|merge({ page: p })) }}"
                        class="rounded-full border px-4 py-2 text-sm {{ p == pagination.page ? 'border-black bg-black text-white' : 'border-gray-300 hover:bg-gray-50' }}"
                    >
                        {{ p }}
                    </a>
                {% endfor %}

                {% if pagination.hasNextPage %}
                    <a
                        href="{{ path(routeName, query|merge({ page: pagination.nextPage })) }}"
                        class="rounded-full border border-gray-300 px-4 py-2 text-sm hover:bg-gray-50"
                    >
                        Volgende
                    </a>
                {% endif %}
            </nav>
        {% endif %}
    {% endif %}

</div>
{% endblock %}