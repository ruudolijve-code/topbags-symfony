{% extends 'base.html.twig' %}

{% block title %}Inloggen | Topbags{% endblock %}

{% block body %}

<div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid lg:grid-cols-2 gap-16 items-start">

        <div>
            <h1 class="text-3xl font-semibold tracking-tight mb-8">
                Inloggen
            </h1>

            <p class="text-lg font-medium mb-6">
                Bestaande klanten
            </p>

            {% if error %}
                <div class="mb-6 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                    Inloggen is niet gelukt. Controleer je e-mailadres en wachtwoord.
                </div>
            {% endif %}

            <form method="post" class="space-y-6">
                <div>
                    <label for="email" class="block text-sm font-medium text-gray-900 mb-2">
                        E-mailadres *
                    </label>

                    <input
                        type="email"
                        id="email"
                        name="email"
                        value="{{ lastUsername }}"
                        autocomplete="email"
                        required
                        class="w-full rounded-lg border border-gray-300 px-4 py-3"
                    >
                </div>

                <div>
                    <label for="password" class="block text-sm font-medium text-gray-900 mb-2">
                        Wachtwoord *
                    </label>

                    <input
                        type="password"
                        id="password"
                        name="password"
                        autocomplete="current-password"
                        required
                        class="w-full rounded-lg border border-gray-300 px-4 py-3"
                    >
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button
                    type="submit"
                    class="w-full bg-black hover:bg-black text-white font-semibold py-3 rounded-lg transition"
                >
                    Inloggen
                </button>

                <div class="text-sm text-gray-700 mt-2">
                    <a href="#" class="hover:underline">
                        Wachtwoord vergeten?
                    </a>
                </div>
            </form>
        </div>

        <div class="border-l border-gray-200 lg:pl-12">
            <h2 class="text-3xl font-semibold mb-6">
                Nog geen account?
            </h2>

            <p class="text-lg font-medium mb-8 max-w-xl">
                Maak nu gratis je account aan en spaar mee voor korting én voordelen
            </p>

            <div class="space-y-6 mb-10">
                <div class="flex items-start gap-4">
                    <div class="w-6 h-6 flex-shrink-0 flex items-center justify-center text-gray-700">
                        <span class="block w-6 h-6 [&>svg]:w-6 [&>svg]:h-6 [&>svg]:block [&>svg]:max-w-none">
                            {{ include('partials/icons/stamp.svg.twig') }}
                        </span>
                    </div>

                    <p class="text-gray-800 leading-relaxed">
                        Ontvang een stempel bij elke €25 aankoop
                    </p>
                </div>

                <div class="flex items-start gap-4">
                    <div class="w-6 h-6 flex-shrink-0 flex items-center justify-center text-gray-700">
                        <span class="block w-6 h-6 [&>svg]:w-6 [&>svg]:h-6 [&>svg]:block [&>svg]:max-w-none">
                            {{ include('partials/icons/gift.svg.twig') }}
                        </span>
                    </div>

                    <p class="text-gray-800 leading-relaxed">
                        Spaar voor kortingen en gratis cadeaus
                    </p>
                </div>

                <div class="flex items-start gap-4">
                    <div class="w-6 h-6 flex-shrink-0 flex items-center justify-center text-gray-700">
                        <span class="block w-6 h-6 [&>svg]:w-6 [&>svg]:h-6 [&>svg]:block [&>svg]:max-w-none">
                            {{ include('partials/icons/party.svg.twig') }}
                        </span>
                    </div>

                    <p class="text-gray-800 leading-relaxed">
                        Extra stempels via acties en verrassingen
                    </p>
                </div>
            </div>

            <a href="{{ path('account_register') }}"
               class="block text-center bg-black hover:bg-black text-white font-semibold py-4 rounded-lg transition">
                Gratis account aanmaken
            </a>
        </div>

    </div>
</div>

{% endblock %}