{% extends 'base.html.twig' %}

{% block title %}Tweestapsverificatie{% endblock %}

{% block body %}
    <div class="min-h-screen flex items-center justify-center bg-gray-50 px-4">
        <div class="w-full max-w-md bg-white rounded-2xl shadow p-8">
            <h1 class="text-2xl font-semibold mb-2">Tweestapsverificatie</h1>
            <p class="text-sm text-gray-600 mb-6">
                Vul de code uit Google Authenticator in om verder te gaan.
            </p>

            {% if authenticationError %}
                <div class="mb-4 rounded-lg bg-red-50 text-red-700 px-4 py-3 text-sm">
                    De ingevoerde verificatiecode is ongeldig. Probeer het opnieuw.
                </div>
            {% endif %}

            <form action="{{ path('2fa_login_check') }}" method="post" class="space-y-4">
                <div>
                    <label for="_auth_code" class="block text-sm font-medium text-gray-700 mb-1">
                        Authenticatiecode
                    </label>
                    <input
                        id="_auth_code"
                        type="text"
                        name="_auth_code"
                        autocomplete="one-time-code"
                        inputmode="numeric"
                        autofocus
                        class="w-full rounded-lg border border-gray-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-black"
                    >
                </div>

                {% if displayTrustedOption %}
                    <label class="flex items-center gap-2 text-sm text-gray-700">
                        <input type="checkbox" name="_trusted">
                        Dit apparaat vertrouwen
                    </label>
                {% endif %}

                {% if isCsrfProtectionEnabled %}
                    <input type="hidden" name="{{ csrfParameterName }}" value="{{ csrf_token(csrfTokenId) }}">
                {% endif %}

                <button
                    type="submit"
                    class="w-full rounded-lg bg-black text-white py-3 font-medium hover:opacity-90"
                >
                    Inloggen
                </button>
            </form>

            <div class="mt-4 text-sm">
                <a href="{{ path('admin_login') }}" class="text-gray-500 hover:text-black">
                    Annuleren
                </a>
            </div>
        </div>
    </div>
{% endblock %}