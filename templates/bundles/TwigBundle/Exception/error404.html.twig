{% extends 'base.html.twig' %}

{% block title %}Pagina niet gevonden – Topbags{% endblock %}

{% block body %}
<section class="mx-auto max-w-7xl px-6 py-12 lg:py-16">
    <div class="grid items-center gap-10 lg:grid-cols-2">
        <div>
            <p class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-gray-500">
                404 fout
            </p>

            <h1 class="mb-6 text-4xl font-bold leading-tight text-gray-900 md:text-5xl">
                Deze pagina konden we niet vinden
            </h1>

            <p class="mb-4 max-w-xl text-lg leading-relaxed text-gray-600">
                Mogelijk bestaat deze pagina niet meer, is de link verouderd of is de pagina verplaatst
                naar een nieuwe locatie binnen Topbags.
            </p>

            <p class="mb-8 max-w-xl text-base leading-relaxed text-gray-500">
                Gebruik de zoekfunctie of ga direct naar een populaire categorie.
            </p>

            <div class="mb-10 flex flex-col gap-3 sm:flex-row">
                <a
                    href="{{ path('home') }}"
                    class="inline-flex items-center justify-center rounded-xl bg-black px-6 py-3 text-sm font-semibold text-white hover:bg-gray-900"
                >
                    Naar de homepage
                </a>

                <a
                    href="/winkel"
                    class="inline-flex items-center justify-center rounded-xl border border-gray-300 px-6 py-3 text-sm font-semibold text-gray-900 hover:bg-gray-50"
                >
                    Naar de winkel
                </a>
            </div>

            <form action="{{ path('shop_search') is defined ? path('shop_search') : path('home') }}" method="get" class="mb-10">
                <label for="q" class="mb-2 block text-sm font-medium text-gray-700">
                    Zoek een tas, koffer of rugzak
                </label>

                <div class="flex flex-col gap-3 sm:flex-row">
                    <input
                        type="text"
                        id="q"
                        name="q"
                        placeholder="Waar ben je naar op zoek?"
                        class="w-full rounded-xl border border-gray-300 px-4 py-3 text-sm text-gray-900 outline-none focus:border-black"
                    >
                    <button
                        type="submit"
                        class="inline-flex items-center justify-center rounded-xl bg-[#4c3228] px-6 py-3 text-sm font-semibold text-white hover:opacity-90"
                    >
                        Zoeken
                    </button>
                </div>
            </form>

            <div>
                <h2 class="mb-4 text-lg font-semibold text-gray-900">
                    Populaire categorieën
                </h2>

                <div class="flex flex-wrap gap-3">
                    <a href="/categorie/koffers" class="rounded-full border border-gray-300 px-4 py-2 text-sm text-gray-800 hover:bg-gray-50">
                        Koffers
                    </a>
                    <a href="/categorie/rugzakken" class="rounded-full border border-gray-300 px-4 py-2 text-sm text-gray-800 hover:bg-gray-50">
                        Rugzakken
                    </a>
                    <a href="/categorie/schoudertassen" class="rounded-full border border-gray-300 px-4 py-2 text-sm text-gray-800 hover:bg-gray-50">
                        Schoudertassen
                    </a>
                    <a href="/categorie/laptoptassen" class="rounded-full border border-gray-300 px-4 py-2 text-sm text-gray-800 hover:bg-gray-50">
                        Laptoptassen
                    </a>
                    <a href="/categorie/reistassen" class="rounded-full border border-gray-300 px-4 py-2 text-sm text-gray-800 hover:bg-gray-50">
                        Reistassen
                    </a>
                </div>
            </div>
        </div>

        <div class="order-first lg:order-none">
            <div class="overflow-hidden rounded-3xl bg-[#f5f1ec]">
                <img
                    src="{{ asset('images/404-topbags.jpg') }}"
                    alt="Pagina niet gevonden"
                    class="h-full w-full object-cover"
                >
            </div>
        </div>
    </div>
</section>
{% endblock %}