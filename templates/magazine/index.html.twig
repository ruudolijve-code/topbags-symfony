{# templates/magazine/index.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}Topbags Gids | Kofferadvies & reistips{% endblock %}

{% block body %}
<section class="bg-[#f4f1ea] py-16">
    <div class="container max-w-6xl">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">
            Topbags gids
        </p>

        <h1 class="mt-3 text-4xl font-semibold tracking-tight text-gray-900 lg:text-5xl">
            Kofferadvies, handbagage regels en reistips
        </h1>

        <p class="mt-4 max-w-2xl text-lg text-gray-600">
            Praktische uitleg van de kofferspecialist van Twente. Van kofferadvies tot bagageregels, verhuur, reparatie en reistips.
        </p>
    </div>
</section>

{% if articles is not empty %}
    {% set featured = articles|first %}
    {% set rest = articles|slice(1) %}

    <section class="py-12">
        <div class="container max-w-6xl">

            {# Featured article #}
            <a href="{{ path('magazine_show', { slug: featured.slug }) }}"
               class="grid overflow-hidden rounded-3xl border border-gray-200 bg-white shadow-sm transition hover:shadow-md lg:grid-cols-2">

                {% if featured.heroImage %}
                    <div class="aspect-[4/3] bg-gray-100 lg:aspect-auto">
                        <img
                            src="{{ asset(featured.heroImage) }}"
                            alt="{{ featured.title }}"
                            class="h-full w-full object-cover"
                            loading="eager"
                        >
                    </div>
                {% endif %}

                <div class="p-8 lg:p-10">
                    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">
                        {{ featured.category ?: 'Gids' }}
                    </p>

                    <h2 class="mt-4 text-3xl font-semibold tracking-tight text-gray-900">
                        {{ featured.title }}
                    </h2>

                    {% if featured.excerpt %}
                        <p class="mt-4 text-base leading-7 text-gray-600">
                            {{ featured.excerpt }}
                        </p>
                    {% endif %}

                    <span class="mt-6 inline-flex rounded-full bg-gray-900 px-5 py-3 text-sm font-semibold text-white">
                        Lees artikel
                    </span>
                </div>
            </a>

            {# Article grid #}
            <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
                {% for article in rest %}
                    <a href="{{ path('magazine_show', { slug: article.slug }) }}"
                       class="group overflow-hidden rounded-3xl border border-gray-200 bg-white shadow-sm transition hover:shadow-md">

                        {% if article.heroImage %}
                            <div class="aspect-[4/3] bg-gray-100">
                                <img
                                    src="{{ asset(article.heroImage) }}"
                                    alt="{{ article.title }}"
                                    class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
                                    loading="lazy"
                                >
                            </div>
                        {% endif %}

                        <div class="p-6">
                            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">
                                {{ article.category ?: 'Gids' }}
                            </p>

                            <h2 class="mt-3 text-xl font-semibold leading-snug text-gray-900">
                                {{ article.title }}
                            </h2>

                            {% if article.excerpt %}
                                <p class="mt-3 text-sm leading-6 text-gray-600">
                                    {{ article.excerpt }}
                                </p>
                            {% endif %}
                        </div>
                    </a>
                {% endfor %}
            </div>

        </div>
    </section>
{% else %}
    <section class="py-12">
        <div class="container">
            <p class="text-gray-600">Er zijn nog geen gidsartikelen gepubliceerd.</p>
        </div>
    </section>
{% endif %}
{% endblock %}