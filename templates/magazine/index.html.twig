{# templates/magazine/index.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}{{ magazine.pageTitle }}{% endblock %}

{% block body %}

<section class="bg-[#f4f1ea] py-16">
    <div class="container max-w-6xl">

        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">
            {{ magazine.label }}
        </p>

        <h1 class="mt-3 text-4xl font-semibold tracking-tight text-gray-900 lg:text-5xl">
            {{ magazine.heading }}
        </h1>

        <p class="mt-4 max-w-3xl text-lg text-gray-600">
            {{ magazine.intro }}
        </p>

    </div>
</section>

{% if featured or articles is not empty %}
    <section class="py-12">
        <div class="container max-w-6xl">

            {% if featured %}
                <a
                    href="{{ path(magazine.showRoute, { slug: featured.slug }) }}"
                    class="grid overflow-hidden rounded-3xl border border-gray-200 bg-white shadow-sm transition hover:shadow-md lg:grid-cols-2"
                >
                    {% if featured.heroImage %}
                        <div class="aspect-[4/3] overflow-hidden bg-gray-100 lg:aspect-auto">
                            <img
                                src="{{ asset(featured.heroImage) }}"
                                alt="{{ featured.title }}"
                                class="h-full w-full object-cover"
                                loading="eager"
                            >
                        </div>
                    {% endif %}

                    <div class="p-8 lg:p-10">

                        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-amber-700">
                            Uitgelicht artikel
                        </p>

                        <div class="mt-4 flex flex-wrap items-center gap-2 text-xs uppercase tracking-[0.16em] text-gray-500">

                            <span>{{ featured.category ?: 'Magazine' }}</span>

                            {% if featured.publishedAt %}
                                <span class="text-gray-300">•</span>

                                <time datetime="{{ featured.publishedAt|date('Y-m-d') }}">
                                    {{ featured.publishedAt|date('d M Y') }}
                                </time>
                            {% endif %}

                            {% if
                                featured.updatedAt
                                and featured.publishedAt
                                and featured.updatedAt|date('Y-m-d') != featured.publishedAt|date('Y-m-d')
                            %}
                                <span class="text-gray-300">•</span>
                                <span>Bijgewerkt {{ featured.updatedAt|date('d M Y') }}</span>
                            {% endif %}

                            <span class="text-gray-300">•</span>
                            <span>{{ featured.readingTime }} min. leestijd</span>

                        </div>

                        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-gray-900">
                            {{ featured.title }}
                        </h2>

                        {% if featured.excerpt %}
                            <p class="mt-4 text-base leading-7 text-gray-600">
                                {{ featured.excerpt }}
                            </p>
                        {% endif %}

                        <span class="mt-6 inline-flex rounded-full bg-gray-900 px-5 py-3 text-sm font-semibold text-white">
                            Lees artikel
                        </span>

                    </div>
                </a>
            {% endif %}

            <div class="{{ featured ? 'mt-10' : '' }} grid gap-6 md:grid-cols-2 lg:grid-cols-3">

                {% for article in articles %}
                    <a
                        href="{{ path(magazine.showRoute, { slug: article.slug }) }}"
                        class="group overflow-hidden rounded-3xl border border-gray-200 bg-white shadow-sm transition hover:shadow-md"
                    >
                        {% if article.heroImage %}
                            <div class="aspect-[4/3] overflow-hidden bg-gray-100">
                                <img
                                    src="{{ asset(article.heroImage) }}"
                                    alt="{{ article.title }}"
                                    class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
                                    loading="lazy"
                                >
                            </div>
                        {% endif %}

                        <div class="p-6">

                            <div class="flex flex-wrap items-center gap-2 text-xs uppercase tracking-[0.16em] text-gray-500">

                                <span>{{ article.category ?: 'Magazine' }}</span>

                                {% if article.publishedAt %}
                                    <span class="text-gray-300">•</span>

                                    <time datetime="{{ article.publishedAt|date('Y-m-d') }}">
                                        {{ article.publishedAt|date('d M Y') }}
                                    </time>
                                {% endif %}

                                {% if
                                    article.updatedAt
                                    and article.publishedAt
                                    and article.updatedAt|date('Y-m-d') != article.publishedAt|date('Y-m-d')
                                %}
                                    <span class="text-gray-300">•</span>
                                    <span>Bijgewerkt {{ article.updatedAt|date('d M Y') }}</span>
                                {% endif %}

                                <span class="text-gray-300">•</span>
                                <span>{{ article.readingTime }} min. leestijd</span>

                            </div>

                            <h2 class="mt-3 text-xl font-semibold leading-snug text-gray-900">
                                {{ article.title }}
                            </h2>

                            {% if article.excerpt %}
                                <p class="mt-3 text-sm leading-6 text-gray-600">
                                    {{ article.excerpt }}
                                </p>
                            {% endif %}

                        </div>
                    </a>
                {% else %}
                    {% if not featured %}
                        <div class="col-span-full rounded-3xl border border-gray-200 bg-white p-8">
                            <p class="text-gray-600">
                                {{ magazine.emptyMessage }}
                            </p>
                        </div>
                    {% endif %}
                {% endfor %}

            </div>

        </div>
    </section>
{% else %}
    <section class="py-12">
        <div class="container max-w-6xl">
            <div class="rounded-3xl border border-gray-200 bg-white p-8">
                <p class="text-gray-600">
                    {{ magazine.emptyMessage }}
                </p>
            </div>
        </div>
    </section>
{% endif %}

{% endblock %}