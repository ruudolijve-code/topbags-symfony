{# templates/magazine/show.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}
    {{ article.seoTitle ?: article.title }}
{% endblock %}

{% block meta_description %}
    {{ article.seoDescription ?: article.excerpt }}
{% endblock %}

{% block body %}
<article>

    {# Hero #}
    <section class="bg-[#f4f1ea] py-16">
        <div class="container max-w-4xl">

            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">
                {{ article.category ?: 'Topbags Magazine' }}
            </p>

            <div class="mt-4 flex flex-wrap items-center gap-2 text-sm text-gray-500">
                {% if article.publishedAt %}
                    <time datetime="{{ article.publishedAt|date('Y-m-d') }}">
                        Gepubliceerd op {{ article.publishedAt|date('d-m-Y') }}
                    </time>
                {% endif %}

                {% if article.updatedAt and article.publishedAt and article.updatedAt|date('Y-m-d') != article.publishedAt|date('Y-m-d') %}
                    <span class="text-gray-300">•</span>

                    <time datetime="{{ article.updatedAt|date('Y-m-d') }}">
                        Laatst bijgewerkt op {{ article.updatedAt|date('d-m-Y') }}
                    </time>
                {% endif %}
            </div>

            <h1 class="mt-3 text-4xl font-semibold tracking-tight text-gray-900 lg:text-5xl">
                {{ article.title }}
            </h1>

            {% if article.excerpt %}
                <p class="mt-5 text-lg leading-8 text-gray-700">
                    {{ article.excerpt }}
                </p>
            {% endif %}

            {% if article.heroImage %}
                <div class="mt-10 overflow-hidden rounded-3xl shadow-sm">
                    <img
                        src="{{ asset(article.heroImage) }}"
                        alt="{{ article.title }}"
                        class="w-full object-cover"
                        loading="eager"
                    >
                </div>
            {% endif %}

        </div>
    </section>

    {# Artikel #}
    <section class="py-12">
        <div class="container max-w-4xl">
            <div class="magazine-content max-w-none">
                {{ article.content|raw }}
            </div>
        </div>
    </section>

    {# FAQ #}
    {% set activeFaqs = article.faqs|filter(faq => faq.isActive) %}

    {% if activeFaqs|length > 0 %}
        <section class="pb-16">
            <div class="container max-w-4xl">

                <h2 class="text-3xl font-semibold tracking-tight text-gray-900">
                    Veelgestelde vragen
                </h2>

                <div class="mt-8 space-y-4">
                    {% for faq in activeFaqs %}
                        <details class="group rounded-2xl border border-gray-200 bg-white px-6 py-5 shadow-sm">
                            <summary class="flex cursor-pointer list-none items-center justify-between gap-6">
                                <span class="text-lg font-semibold text-gray-900">
                                    {{ faq.question }}
                                </span>

                                <span class="text-xl font-semibold text-amber-600 transition-transform group-open:rotate-180">
                                    ˅
                                </span>
                            </summary>

                            <div class="magazine-content mt-4 border-t border-gray-100 pt-4 text-gray-600">
                                {{ faq.answer|raw }}
                            </div>
                        </details>
                    {% endfor %}
                </div>

            </div>
        </section>

        {% set faqEntities = [] %}

        {% for faq in activeFaqs %}
            {% set faqEntities = faqEntities|merge([
                {
                    '@type': 'Question',
                    'name': faq.question|striptags,
                    'acceptedAnswer': {
                        '@type': 'Answer',
                        'text': faq.answer|striptags
                    }
                }
            ]) %}
        {% endfor %}

        <script type="application/ld+json">
    {{ {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        'mainEntity': faqEntities
    }|json_encode(constant('JSON_UNESCAPED_SLASHES'))|raw }}
        </script>
    {% endif %}

    {% if article.slug == 'lichtste-koffers-2026' and lightweightSuitcaseItems is defined and lightweightSuitcaseItems|length > 0 %}
        <section class="pb-16">
            <div class="container">

                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">
                    Dynamisch berekend door Topbags
                </p>

                <h2 class="mt-2 text-2xl font-semibold tracking-tight text-gray-900">
                    Lichtste koffers op basis van gram per liter
                </h2>

                <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
                    {% for item in lightweightSuitcaseItems %}
                        <div>
                            {% include 'shop/component/card/_card_functional.html.twig' with {
                                product: item.product,
                                variant: item.variant,
                                mediaPath: item.mediaPath
                            } only %}

                            <div class="mt-2 rounded-xl bg-amber-50 px-4 py-2 text-sm font-semibold text-amber-800">
                                {{ item.gramPerLiter }} g/L
                            </div>
                        </div>
                    {% endfor %}
                </div>

            </div>
        </section>
    {% endif %}

    {# Gerelateerde producten #}
    {% if relatedProductItems is defined and relatedProductItems|length > 0 %}
        <section class="pb-16">
            <div class="container">

                <div class="mb-6 flex items-end justify-between gap-4">
                    <div>
                        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">
                            Aanbevolen door Topbags
                        </p>

                        <h2 class="mt-2 text-2xl font-semibold tracking-tight text-gray-900">
                            Populaire koffers met TSA-slot
                        </h2>
                    </div>

                    <a href="{{ path('shop_index') }}"
                       class="hidden text-sm font-semibold text-gray-900 underline underline-offset-4 md:inline">
                        Bekijk alle koffers
                    </a>
                </div>

                <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
                    {% for item in relatedProductItems %}
                        {% include 'shop/component/card/_card_functional.html.twig' with {
                            product: item.product,
                            variant: item.variant,
                            mediaPath: item.mediaPath
                        } only %}
                    {% endfor %}
                </div>

            </div>
        </section>
    {% endif %}

    {# Gerelateerde categorie fallback #}
    {% if article.relatedCategorySlug %}
        <section class="pb-16">
            <div class="container max-w-5xl">
                <div class="rounded-3xl border border-gray-200 bg-white p-8 shadow-sm">
                    <h2 class="text-2xl font-semibold text-gray-900">
                        Bekijk ook onze collectie
                    </h2>

                    <p class="mt-3 text-gray-600">
                        Wil je direct een passende koffer of reistas kiezen? Bekijk dan onze collectie die aansluit bij dit artikel.
                    </p>

                    <a href="{{ path('category_show', { slug: article.relatedCategorySlug }) }}"
                       class="mt-6 inline-flex rounded-full bg-gray-900 px-6 py-3 text-sm font-semibold text-white">
                        Bekijk {{ article.relatedCategorySlug|replace({'-': ' '}) }}
                    </a>
                </div>
            </div>
        </section>
    {% endif %}

    {# CTA #}
    <section class="pb-16">
        <div class="container max-w-5xl">

            <div class="rounded-3xl bg-[#f4f1ea] p-8 shadow-sm">

                <h2 class="text-2xl font-semibold text-gray-900">
                    Advies nodig?
                </h2>

                <p class="mt-3 text-gray-600">
                    Kom langs bij Holtkamp Tassen & Koffers in Hengelo of bekijk direct onze collectie online. Als kofferspecialist van Twente helpen wij je graag bij het kiezen van de juiste koffer, reistas of rugzak.
                </p>

                <div class="mt-6 flex flex-wrap gap-3">

                    <a href="{{ path('shop_index') }}"
                       class="inline-flex rounded-full bg-gray-900 px-6 py-3 text-sm font-semibold text-white">
                        Bekijk koffers & reistassen
                    </a>

                    <a href="{{ path('service_store') }}"
                       class="inline-flex rounded-full border border-gray-300 bg-white px-6 py-3 text-sm font-semibold text-gray-900">
                        Bezoek onze winkel
                    </a>

                </div>

            </div>

        </div>
    </section>

</article>
{% endblock %}