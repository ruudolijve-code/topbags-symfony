{% extends 'base.html.twig' %}

{% block title %}
    De mooiste leren tassen – Topbags
{% endblock %}

{% block body %}
<div class="w-full border-b border-gray-200 bg-grey-50">
    <div class="mx-auto max-w-7xl px-6 py-8">

        <header class="mb-8">
            <h1 class="mb-4 text-3xl font-bold">
                De mooiste tassen vind je bij Topbags
            </h1>

            <div class="max-w-3xl text-lg text-gray-600">
                Ontdek onze collectie leren tassen en fashionable bags.
            </div>
        </header>

        <div class="grid grid-cols-1 gap-8 lg:grid-cols-4">

            {# Filters #}
            <aside class="rounded-xl bg-white p-6 shadow-sm lg:col-span-1">
                <form method="get" class="space-y-6">

                    {% if allowedFilters is defined and 'brands' in allowedFilters %}
                        {% include 'shop/filter/_filter_brands.html.twig' %}
                    {% endif %}

                    {% if allowedFilters is defined and 'color' in allowedFilters %}
                        {% include 'shop/filter/_filter_color.html.twig' %}
                    {% endif %}

                    {% if allowedFilters is defined and 'cta' in allowedFilters %}
                        {% include 'shop/filter/_filter_cta.html.twig' %}
                    {% endif %}

                </form>
            </aside>

            {# Product grid #}
            <section class="lg:col-span-3">

                <div class="mb-4 text-sm text-gray-500">
                    {{ items|length }} modellen gevonden
                </div>

                {% if items is not empty %}
                    <div class="columns-2 gap-8 space-y-8 md:columns-3 lg:columns-4">
                        {% for item in items %}
                            {% include 'shop/component/card/_card.html.twig' with {
                                context: 'bags',
                                product: item.product,
                                variant: item.variant,
                                master: item.master,
                                mediaPath: item.mediaPath,
                                availability: item.availability
                            } only %}
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="rounded-xl bg-white p-8 text-gray-500 shadow-sm">
                        Geen producten gevonden.
                    </div>
                {% endif %}

            </section>

        </div>
    </div>
</div>

{% if pagination is defined and pagination.totalPages > 1 %}
    <nav class="mt-10 flex flex-wrap items-center justify-center gap-2">
        {% set routeName = app.request.attributes.get('_route') %}
        {% set query = app.request.query.all %}

        {% if pagination.hasPreviousPage %}
            <a
                href="{{ path(routeName, query|merge({ page: pagination.previousPage })) }}"
                class="rounded-full border border-gray-300 px-4 py-2 text-sm hover:bg-gray-50"
            >
                Vorige
            </a>
        {% endif %}

        {% for p in pagination.pages %}
            <a
                href="{{ path(routeName, query|merge({ page: p })) }}"
                class="rounded-full border px-4 py-2 text-sm {{ p == pagination.page ? 'border-black bg-black text-white' : 'border-gray-300 hover:bg-gray-50' }}"
            >
                {{ p }}
            </a>
        {% endfor %}

        {% if pagination.hasNextPage %}
            <a
                href="{{ path(routeName, query|merge({ page: pagination.nextPage })) }}"
                class="rounded-full border border-gray-300 px-4 py-2 text-sm hover:bg-gray-50"
            >
                Volgende
            </a>
        {% endif %}
    </nav>
{% endif %}
{% endblock %}