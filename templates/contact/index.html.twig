{% extends 'base.html.twig' %}

{% block title %}Contact | Topbags{% endblock %}

{% block body %}

<section class="relative bg-white">

  {# =========================================================
     HERO
     ========================================================= #}
  <div class="relative overflow-hidden border-b border-gray-200">

    <div class="mx-auto max-w-6xl px-4 py-16 grid md:grid-cols-2 gap-10 items-center">

      <div>
        <h1 class="text-3xl md:text-4xl font-semibold text-gray-900 leading-tight">
          Persoonlijk advies <br> of een vraag?
        </h1>

        <p class="mt-4 text-gray-600 text-base leading-relaxed max-w-lg">
          Wij helpen je graag bij het kiezen van de juiste koffer,
          het huren van bagage of een reparatievraag.
          Je ontvangt meestal binnen <strong>1 werkdag</strong> een reactie.
        </p>

        <div class="mt-8 flex flex-wrap gap-4">
          <a href="tel:+31642485211"
             class="inline-flex items-center rounded-full border border-gray-300 px-5 py-2 text-sm font-semibold text-gray-900 hover:bg-gray-50 transition">
            📞 Bel ons
          </a>

          <a href="https://wa.me/31642485211"
             target="_blank" rel="noopener"
             class="inline-flex items-center rounded-full bg-green-600 px-5 py-2 text-sm font-semibold text-white hover:bg-green-700 transition">
            💬 WhatsApp
          </a>
        </div>
      </div>

      <div class="rounded-3xl bg-amber-50 border border-amber-200 p-8 shadow-sm">
        <h3 class="text-sm font-semibold text-gray-900">
          Waarom contact opnemen met Topbags?
        </h3>

        <ul class="mt-6 space-y-4 text-sm text-gray-700">
          <li class="flex gap-3"><span class="text-amber-600">✔</span><span>Meer dan 100 jaar ervaring in tassen & koffers</span></li>
          <li class="flex gap-3"><span class="text-amber-600">✔</span><span>Officieel dealer van gerenommeerde merken</span></li>
          <li class="flex gap-3"><span class="text-amber-600">✔</span><span>Persoonlijk advies op basis van jouw reis</span></li>
          <li class="flex gap-3"><span class="text-amber-600">✔</span><span>Snelle reactie – meestal binnen 1 werkdag</span></li>
          <li class="flex gap-3"><span class="text-amber-600">✔</span><span>Specialist in reparatie & verhuur</span></li>
        </ul>
      </div>

    </div>
  </div>

  {# =========================================================
     FORM
     ========================================================= #}
  <div class="mx-auto max-w-4xl px-4 py-16">

    <div class="rounded-3xl border border-gray-200 bg-white p-10 shadow-sm">

      {# ================= FLASH MESSAGES ================= #}
      {% for message in app.flashes('success') %}
        <div class="mb-6 rounded-2xl border border-emerald-200 bg-emerald-50 p-4 text-emerald-800 shadow-sm">
          <div class="flex items-center gap-2 text-sm font-medium">
            <span>✔</span>
            <span>{{ message }}</span>
          </div>
        </div>
      {% endfor %}

      {% for message in app.flashes('error') %}
        <div class="mb-6 rounded-2xl border border-red-200 bg-red-50 p-4 text-red-800 shadow-sm">
          <div class="flex items-center gap-2 text-sm font-medium">
            <span>⚠</span>
            <span>{{ message }}</span>
          </div>
        </div>
      {% endfor %}

      {{ form_start(form, { attr: { class: 'space-y-6' } }) }}

        <div class="grid md:grid-cols-2 gap-6">

          <div>
            {{ form_label(form.name, null, { label_attr: { class: 'block text-sm font-medium text-gray-900 mb-2' } }) }}
            {{ form_widget(form.name, { attr: { class: 'w-full rounded-xl border border-gray-300 bg-white px-4 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500' } }) }}
            {{ form_errors(form.name) }}
          </div>

          <div>
            {{ form_label(form.email, null, { label_attr: { class: 'block text-sm font-medium text-gray-900 mb-2' } }) }}
            {{ form_widget(form.email, { attr: { class: 'w-full rounded-xl border border-gray-300 bg-white px-4 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500' } }) }}
            {{ form_errors(form.email) }}
          </div>

        </div>

        <div>
          {{ form_label(form.phone, null, { label_attr: { class: 'block text-sm font-medium text-gray-900 mb-2' } }) }}
          {{ form_widget(form.phone, { attr: { class: 'w-full rounded-xl border border-gray-300 bg-white px-4 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500' } }) }}
          {{ form_errors(form.phone) }}
        </div>

        <div>
          {{ form_label(form.subject, null, { label_attr: { class: 'block text-sm font-medium text-gray-900 mb-2' } }) }}
          {{ form_widget(form.subject, { attr: { class: 'w-full rounded-xl border border-gray-300 bg-white px-4 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500' } }) }}
          {{ form_errors(form.subject) }}
        </div>

        <div>
          {{ form_label(form.message, null, { label_attr: { class: 'block text-sm font-medium text-gray-900 mb-2' } }) }}
          {{ form_widget(form.message, { attr: { class: 'w-full rounded-xl border border-gray-300 bg-white px-4 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500' } }) }}
          {{ form_errors(form.message) }}
        </div>

        {{ form_widget(form.source) }}

        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between mt-6">
          <p class="text-xs text-gray-500 max-w-sm">
            Door dit formulier te versturen ga je akkoord met onze privacyverklaring.
            We gebruiken je gegevens uitsluitend om je vraag te beantwoorden.
          </p>

          <button type="submit"
                  class="inline-flex items-center rounded-full bg-amber-600 px-6 py-3 text-sm font-semibold text-white hover:bg-amber-700 transition shadow-sm">
            Bericht verzenden →
          </button>
        </div>

      {{ form_end(form) }}

    </div>

  </div>

</section>

{% endblock %}