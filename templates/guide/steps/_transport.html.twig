<h1 class="text-2xl font-semibold mt-10 mb-6">
    Hoe ga je reizen?
</h1>

{% set transports = {
    'plane': 'Vliegtuig',
    'car': 'Auto',
    'train': 'Trein',
    'bus': 'Bus'
} %}

<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
{% for key, label in transports %}

    {% set nextStep = key == 'plane' ? 'airline' : 'duration' %}

    <a
        href="{{ path(
            'guide_index',
            app.request.query.all | merge({
                step: nextStep,
                transport: key
            })
        ) }}"
        class="p-4 border rounded-xl text-center hover:border-black transition"
    >
        {{ label }}
    </a>

{% endfor %}
</div>

<div class="mt-6">
    <a
        href="{{ path('guide_index', app.request.query.all | merge({ step: 'travel_type' })) }}"
        class="text-sm text-gray-500 hover:underline"
    >
        ← Terug
    </a>
</div>