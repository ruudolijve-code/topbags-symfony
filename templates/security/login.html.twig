{% extends 'base.html.twig' %}

{% block title %}Admin login{% endblock %}

{% block robots %}
    <meta name="robots" content="noindex, nofollow, noarchive">
{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-6 py-16">
    <h1 class="text-2xl font-semibold mb-6">Admin login</h1>

    {% if error %}
        <div class="mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
            {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
    {% endif %}

    <form method="post" action="{{ path('admin_login') }}" class="space-y-4">
        <div>
            <label for="username" class="block text-sm font-medium text-gray-700 mb-1">E-mail</label>
            <input
                type="email"
                id="username"
                name="email"
                value="{{ last_username }}"
                required
                autofocus
                autocomplete="username"
                class="w-full rounded-md border border-gray-300 px-3 py-2"
            >
        </div>

        <div>
            <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Wachtwoord</label>
            <input
                type="password"
                id="password"
                name="password"
                required
                autocomplete="current-password"
                class="w-full rounded-md border border-gray-300 px-3 py-2"
            >
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button
            type="submit"
            class="w-full rounded-md bg-black px-4 py-3 text-white font-semibold hover:bg-gray-900 transition"
        >
            Inloggen
        </button>
    </form>
</div>
{% endblock %}