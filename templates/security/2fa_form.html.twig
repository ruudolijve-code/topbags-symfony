{% extends 'base.html.twig' %}

{% block title %}Extra verificatie | Topbags{% endblock %}

{% block body %}
<div class="max-w-md mx-auto py-20 px-6">
    <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
        <h1 class="text-2xl font-semibold text-gray-900 mb-3">
            Extra verificatie
        </h1>

        <p class="text-sm text-gray-600 mb-6">
            Vul de 6-cijferige code uit je authenticator-app in.
        </p>

        {% if authenticationError is defined and authenticationError %}
            <div class="mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
                Ongeldige code. Probeer het opnieuw.
            </div>
        {% endif %}

        <form method="post" action="{{ path('2fa_login_check') }}" class="space-y-4">
            <div>
                <label for="_auth_code" class="block text-sm text-gray-600 mb-2">
                    Verificatiecode
                </label>
                <input
                    id="_auth_code"
                    type="text"
                    name="_auth_code"
                    inputmode="numeric"
                    autocomplete="one-time-code"
                    required
                    class="w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:border-gray-900"
                >
            </div>

            <button
                type="submit"
                class="w-full rounded-full bg-black px-5 py-3 text-sm font-semibold text-white hover:bg-gray-900 transition"
            >
                Verifiëren
            </button>
        </form>
    </div>
</div>
{% endblock %}